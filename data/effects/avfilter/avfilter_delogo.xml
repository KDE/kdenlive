<?xml version="1.0"?>
<!DOCTYPE kpartgui>
<effect xmlns="https://www.kdenlive.org" tag="avfilter.delogo" id="avfilter.delogo">
    <name>DeLogo</name>
    <description>Remove logo from input video</description>
    <author>libavfilter</author>
    <parameter type="fakerect" name="kdenlive:fakerect" default="1 1 100 100" opacity="false">
        <name>Logo</name>
        <parammap target="left" source="av.x" max="%width-1" min="1" default="1" />
        <parammap target="top" source="av.y" max="%height-1" min="1" default="1" />
        <parammap target="width" source="av.w" max="%width-1" min="1" default="100" />
        <parammap target="height" source="av.h" max="%height-1" min="1" default="100" />
    </parameter>
    <parameter type="list" name="av.show" default="0" paramlist="0;1">
        <name>Show borders</name>
        <paramlistdisplay>Off,On</paramlistdisplay>
    </parameter>
</effect>
