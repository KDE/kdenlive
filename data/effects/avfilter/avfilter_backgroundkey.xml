<?xml version="1.0"?>
<!DOCTYPE kpartgui>
<effect xmlns="https://www.kdenlive.org" id="avfilter.backgroundkey" tag="avfilter.backgroundkey" type="video">
   <name>Background Key</name>
   <description><![CDATA[Turns a static background into transparency]]></description>
   <author>libavfilter maintainers</author>
   <parameter name="av.threshold" type="animated" max="1" min="0" decimals="2" default="0.08">
      <name>Threshold</name>
      <comment><![CDATA[Set the scene change threshold]]></comment>
   </parameter>
   <parameter name="av.similarity" type="animated" max="100" min="0" decimals="1" default="0.1" factor="100" suffix="%">
      <name>Similarity</name>
      <comment><![CDATA[Set the similarity]]></comment>
   </parameter>
   <parameter name="av.blend" type="animated" max="100" min="0" decimals="0" default="0" factor="100" suffix="%">
      <name>Blend</name>
      <comment><![CDATA[Set the blend value]]></comment>
   </parameter>
</effect>
