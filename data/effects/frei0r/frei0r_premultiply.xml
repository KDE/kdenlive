<?xml version="1.0"?>
<!DOCTYPE kpartgui>
<effect xmlns="https://www.kdenlive.org" id="frei0r.premultiply" tag="frei0r.premultiply" type="video">
   <name>Premultiply or Unpremultiply</name>
   <description><![CDATA[Multiply (or divide) each color component by the pixel's alpha value]]></description>
   <author>Dan Dennedy</author>
   <parameter name="0" type="bool" min="0" max="1" default="0">
      <name>Unpremultiply</name>
      <comment><![CDATA[Whether to unpremultiply instead]]></comment>
   </parameter>
</effect>
