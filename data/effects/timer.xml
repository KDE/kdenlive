    </parameter>
-->
    <parameter type="constant" name="speed" max="1000" min="1.0" default="1.0">
        <name>Speed</name>
        <comment><![CDATA[Clock speed multiplier.<br>
        For example, speed 10.0 makes the timer tick 10 seconds for each second of playback.<br><br>
        Scales Duration but does not affect <i>Start</i> or <i>Offset</i>. For example: start 5s, duration 30s, offset 7s and speed 10.0 will have the timer start at playback time 00:00:05.000 with value 00:00:07, count 10 seconds per second of playback and stop at playback time 00:00:08.000 with value 00:00:37.]]></comment>
    </parameter>
    <parameter type="list" name="direction" default="up" paramlist="up;down">
        <name>Direction</name>
        <comment><![CDATA[Whether the counter should count up from 00:00:00.000 or down from the duration time.]]></comment>
        <paramlistdisplay>Up,Down</paramlistdisplay>
    </parameter>
</effect>