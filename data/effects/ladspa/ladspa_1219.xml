<?xml version="1.0"?>
<!DOCTYPE kpartgui>
<effect xmlns="https://www.kdenlive.org" id="ladspa.1219" tag="ladspa.1219" ladspaid="1219" type="audio">
<name>Auto Phaser</name>
   <description><![CDATA[Auto Phaser (LADSPA 1219)]]></description>
   <author>Steve Harris (http://www.ladspa.org)</author>
   <parameter name="0" type="constant" decimals="3" default="0.250" max="1.000" min="0.000" suffix="s">
      <name>Attack Time</name>
   </parameter>
   <parameter name="1" type="constant" decimals="3" default="0.250" max="1.000" min="0.000" suffix="s">
      <name>Decay Time</name>
   </parameter>
   <parameter name="2" type="constant" decimals="1" default="25.0" max="100.0" min="0.0" factor="100" suffix="%">
      <name>Modulation Depth</name>
   </parameter>
   <parameter name="3" type="constant" decimals="1" default="0.0" max="100.0" min="-100.0" factor="100" suffix="%">
      <name>Feedback</name>
   </parameter>
   <parameter name="4" type="constant" decimals="1" default="1.0" max="2.0" min="0.0">
      <name>Spread (octaves)</name>
   </parameter>
   <parameter type="constant" name="wetness" max="100" min="0" default="1" factor="100" decimals="0">
      <name><![CDATA[Dry/Wet]]></name>
   </parameter>
</effect>
