#: data/effects/frei0r/frei0r_keyspillm0pup.xml:15
#, kde-format
msgid "Color distance,Transparency,Edge inwards,Edge outwards"
msgstr "ໄລຍະຫ່າງສີ,ຄວາມໂປ່ງໃສ,ຂອບເຂົ້າໃນ,ຂອບອອກນອກ"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:18
#, kde-format
msgid "Tolerance"
msgstr "ຄ່າຄວາມຜິດພາດທີ່ຍອມຮັບໄດ້"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:21 data/effects/lumakey.xml:14
#, kde-format
msgid "Slope"
msgstr "ຄວາມຊັນ (Slope)"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:24
#, kde-format
msgid "Hue Gate"
msgstr "ປະຕູສີ (Hue Gate)"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:27
#, kde-format
msgid "Saturation Threshold"
msgstr "ເກນຄວາມອີ່ມໂຕຂອງສີ"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:30
#, kde-format
msgid "Operation 1"
msgstr "ການດຳເນີນການ 1"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:31
#: data/effects/frei0r/frei0r_keyspillm0pup.xml:38
#, kde-format
msgid "None,De-Key,Target,Desaturate,Luma adjust"
msgstr "ບໍ່ມີ,De-Key,ເປົ້າໝາຍ,ລຸດຄວາມອີ່ມໂຕຂອງສີ,ປັບຄວາມສະຫວ່າງ (Luma)"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:34
#, kde-format
msgid "Amount 1"
msgstr "ປະລິມານ 1"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:37
#, kde-format
msgid "Operation 2"
msgstr "ການດຳເນີນການ 2"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:41
#, kde-format
msgid "Amount 2"
msgstr "ປະລິມານ 2"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:44
#, kde-format
msgid "Show Mask"
msgstr "ສະແດງໜ້າກາກ"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:47
#, kde-format
msgid "Mask to Alpha"
msgstr "ໜ້າກາກເປັນອັນຟາ"

#: data/effects/frei0r/frei0r_lenscorrection.xml:4
#, kde-format
msgid "Lens Correction (frei0r)"
msgstr "ການແກ້ໄຂເລນ (frei0r)"

#: data/effects/frei0r/frei0r_lenscorrection.xml:5
#, kde-format
msgid "Allows compensation of lens distortion"
msgstr "ອະນຸຍາດໃຫ້ຊົດເຊີຍການບິດເບືອນຂອງເລນ"

#: data/effects/frei0r/frei0r_lenscorrection.xml:8
#, kde-format
msgid "Horizontal Center"
msgstr "ຈຸດໃຈກາງແນວນອນ"

#: data/effects/frei0r/frei0r_lenscorrection.xml:11
#, kde-format
msgid "Vertical Center"
msgstr "ຈຸດໃຈກາງແນວຕັ້ງ"

#: data/effects/frei0r/frei0r_lenscorrection.xml:14
#, kde-format
msgid "Center Correction"
msgstr "ການແກ້ໄຂຈຸດໃຈກາງ"

#: data/effects/frei0r/frei0r_lenscorrection.xml:17
#, kde-format
msgid "Edges Correction"
msgstr "ການແກ້ໄຂຂອບ"

#: data/effects/frei0r/frei0r_letterb0xed.xml:4
#, kde-format
msgid "Letter-boxing"
msgstr "Letter-boxing (ຂອບດຳ)"

#: data/effects/frei0r/frei0r_letterb0xed.xml:5
#, kde-format
msgid ""
"Adds black borders at the top and bottom for that widescreen cinema look"
msgstr "ເພີ່ມຂອບດຳຢູ່ດ້ານເທິງ ແລະ ດ້ານລຸ່ມສຳລັບຮູບແບບຮູບເງົາຈໍກວ້າງ"

#: data/effects/frei0r/frei0r_letterb0xed.xml:8
#, kde-format
msgid "Border Width"
msgstr "ຄວາມກວ້າງຂອງຂອບ"

#: data/effects/frei0r/frei0r_letterb0xed.xml:10
#, no-c-format, kde-format
msgid ""
"Specify the width of the border<br>\n"
"        as % of half the vertical resolution (100% means both the top and "
"bottom half of the frame are black, i.e. there is no room for the picture)"
msgstr ""
"ລະບຸຄວາມກວ້າງຂອງຂອບ<br>\n"
"        ເປັນ % ຂອງເຄິ່ງໜຶ່ງຂອງຄວາມລະອຽດແນວຕັ້ງ (100% ໝາຍຄວາມວ່າທັງເຄິ່ງເທິງ ແລະ "
"ເຄິ່ງລຸ່ມຂອງເຟຣມເປັນສີດຳ, ເຊັ່ນ: ບໍ່ມີພື້ນທີ່ສຳລັບຮູບ)"

