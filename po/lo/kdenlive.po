#: data/transitions/frei0r/frei0r_lighten.xml:4
#, kde-format
msgid "Lighten"
msgstr "Lighten"

#: data/transitions/frei0r/frei0r_lighten.xml:5
#, kde-format
msgid ""
"Perform a lighten operation between two sources (maximum value of both "
"sources)."
msgstr "ປະຕິບັດການ lighten ລະຫວ່າງສອງແຫຼ່ງ (ຄ່າສູງສຸດຂອງທັງສອງແຫຼ່ງ)."

#: data/transitions/frei0r/frei0r_multiply.xml:4
#, kde-format
msgid "Multiply"
msgstr "Multiply"

#: data/transitions/frei0r/frei0r_multiply.xml:5
#, kde-format
msgid "Perform an RGB[A] multiply operation between the pixel sources."
msgstr "ປະຕິບັດການ RGB[A] multiply ລະຫວ່າງແຫຼ່ງພິກເຊວ."

#: data/transitions/frei0r/frei0r_overlay.xml:4
#, kde-format
msgid "Overlay"
msgstr "Overlay"

#: data/transitions/frei0r/frei0r_overlay.xml:5
#, kde-format
msgid ""
"Perform an RGB[A] overlay operation between the pixel sources, using the "
"generalised algorithm: D = A * (B + (2 * B) * (255 - A))"
msgstr ""
"ປະຕິບັດການ RGB[A] overlay ລະຫວ່າງແຫຼ່ງພິກເຊວ, ໂດຍໃຊ້ອັລກໍຣິທຶມທົ່ວໄປ: D = A * (B + (2 * "
"B) * (255 - A))"

