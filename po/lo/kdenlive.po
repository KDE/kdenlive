#: data/effects/audiospectrum.xml:6
#, kde-format
msgid ""
"An audio visualization filter that draws an audio spectrum on the image."
msgstr "ຟິວເຕີສະແດງພາບສຽງທີ່ແຕ້ມສະເປກຕຣຳສຽງໃສ່ຮູບ."

#: data/effects/audiospectrum.xml:10
#, kde-format
msgid "The type of graph to display the spectrum."
msgstr "ປະເພດຂອງກຣາຟທີ່ຈະສະແດງສະເປກຕຣຳ."

#: data/effects/audiospectrum.xml:11
#, kde-format
msgid "Line,Bar"
msgstr "ເສັ້ນ,ແທ່ງ"

#: data/effects/audiospectrum.xml:15
#, kde-format
msgid ""
"The background color to be applied to the entire frame. The default color is "
"transparent."
msgstr "ສີພື້ນຫຼັງທີ່ຈະໃຊ້ກັບເຟຣມທັງໝົດ. ສີເລີ່ມຕົ້ນແມ່ນໂປ່ງໃສ."

#: data/effects/audiospectrum.xml:18 data/effects/gpstext.xml:80
#, kde-format
msgid "Foreground color"
msgstr "ສີພື້ນໜ້າ"

#: data/effects/audiospectrum.xml:19
#, kde-format
msgid "The color of the waveform."
msgstr "ສີຂອງຮູບຄື້ນ."

#: data/effects/audiospectrum.xml:23
#, kde-format
msgid ""
"The thickness of the line used to draw the waveform for line graph. The "
"thickness of the bar for bar graph."
msgstr "ຄວາມໜາຂອງເສັ້ນທີ່ໃຊ້ແຕ້ມຮູບຄື້ນສຳລັບກຣາຟເສັ້ນ. ຄວາມໜາຂອງແທ່ງສຳລັບກຣາຟແທ່ງ."

#: data/effects/audiospectrum.xml:34 data/effects/audiowaveform.xml:23
#: data/transitions/region.xml:21
#, kde-format
msgid "Fill"
msgstr "ຕື່ມສີ"

#: data/effects/audiospectrum.xml:35
#, kde-format
msgid ""
"Whether the area under the waveform should be filled in. Only applies to "
"line graph type."
msgstr "ພື້ນທີ່ໃຕ້ຮູບຄື້ນຄວນຈະຖືກຕື່ມສີໃສ່ຫຼືບໍ່. ໃຊ້ໄດ້ກັບປະເພດກຣາຟເສັ້ນເທົ່ານັ້ນ."

#: data/effects/audiospectrum.xml:43
#, kde-format
msgid "Draw the points starting with the highest frequency first."
msgstr "ແຕ້ມຈຸດໂດຍເລີ່ມຈາກຄວາມຖີ່ສູງສຸດກ່ອນ."

#: data/effects/audiospectrum.xml:46
#, kde-format
msgid "Line Tension"
msgstr "ຄວາມເຄັ່ງຂອງເສັ້ນ"

#: data/effects/audiospectrum.xml:47
#, kde-format
msgid ""
"Affects the amount of curve in the line interpolating between points. 0.0 = "
"a straight line between points. 100 = very curved lines between points. "
"Values < 0 and > 100 will cause loops in the lines. Only applies to line "
"graph type."
msgstr ""
"ມີຜົນຕໍ່ປະລິມານຄວາມໂຄ້ງໃນເສັ້ນທີ່ເຊື່ອມລະຫວ່າງຈຸດ. 0.0 = ເສັ້ນຊື່ລະຫວ່າງຈຸດ. 100 = "
"ເສັ້ນໂຄ້ງຫຼາຍລະຫວ່າງຈຸດ. ຄ່າທີ່ < 0 ແລະ > 100 ຈະເຮັດໃຫ້ເກີດວົງໃນເສັ້ນ. "
"ໃຊ້ໄດ້ກັບປະເພດກຣາຟເສັ້ນເທົ່ານັ້ນ."

#: data/effects/audiospectrum.xml:50
#, kde-format
msgid "Points"
msgstr "ຈຸດ"

#: data/effects/audiospectrum.xml:51
#, kde-format
msgid ""
"The number of bands to draw in the spectrum. Each band shows up as a data "
"point in the graph."
msgstr "ຈຳນວນແຖບທີ່ຈະແຕ້ມໃນສະເປກຕຣຳ. ແຕ່ລະແຖບສະແດງເປັນຈຸດຂໍ້ມູນໃນກຣາຟ."

#: data/effects/audiospectrum.xml:54 data/effects/dance.xml:8
#, kde-format
msgid "Low Frequency"
msgstr "ຄວາມຖີ່ຕໍ່າ"

#: data/effects/audiospectrum.xml:55
#, kde-format
msgid "The low end of the frequency range to be used for the graph."
msgstr "ຈຸດຕໍ່າສຸດຂອງຊ່ວງຄວາມຖີ່ທີ່ຈະໃຊ້ສຳລັບກຣາຟ."

#: data/effects/audiospectrum.xml:58 data/effects/dance.xml:11
#, kde-format
msgid "High Frequency"
msgstr "ຄວາມຖີ່ສູງ"

#: data/effects/audiospectrum.xml:59
#, kde-format
msgid "The high end of the frequency range to be used for the graph."
msgstr "ຈຸດສູງສຸດຂອງຊ່ວງຄວາມຖີ່ທີ່ຈະໃຊ້ສຳລັບກຣາຟ."

#: data/effects/audiospectrum.xml:62 data/effects/dance.xml:14
#, kde-format
msgid "Level Threshold"
msgstr "ເກນລະດັບ"

#: data/effects/audiospectrum.xml:63
#, kde-format
msgid ""
"The minimum amplitude of sound that must occur within the frequency range to "
"cause the value to be applied."
msgstr "ແອມພລິຈູດຕໍ່າສຸດຂອງສຽງທີ່ຕ້ອງເກີດຂຶ້ນພາຍໃນຊ່ວງຄວາມຖີ່ເພື່ອໃຫ້ຄ່ານັ້ນຖືກນຳໃຊ້."

#: data/effects/audiospectrum.xml:66 data/effects/dance.xml:44
#, kde-format
msgid "Window Size"
msgstr "ຂະໜາດວິນໂດ"

#: data/effects/audiospectrum.xml:67
#, kde-format
msgid ""
"The number of samples that the FFT will be performed on. If window size is "
"less than the number of samples in a frame, extra samples will be ignored. "
"If window size is more than the number of samples in a frame, samples will "
"be buffered from previous frames to fill the window. The buffering is "
"performed as a sliding window so that the most recent samples are always "
"transformed."
msgstr ""
"ຈຳນວນຕົວຢ່າງທີ່ FFT ຈະຖືກດຳເນີນການ. ຖ້າຂະໜາດວິນໂດນ້ອຍກວ່າຈຳນວນຕົວຢ່າງໃນເຟຣມ, "
