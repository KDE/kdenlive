#: data/effects/avfilter/avfilter_stereotools.xml:4
#, kde-format
msgid "Stereo tools"
msgstr "ເຄື່ອງມືສະເຕີຣິໂອ"

#: data/effects/avfilter/avfilter_stereotools.xml:5
#, kde-format
msgid ""
"This filter has some handy utilities to manage stereo signals, for "
"converting M/S stereo recordings to L/R signal while having control over the "
"parameters or spreading the stereo image of master track. "
msgstr ""
"ຟິວເຕີນີ້ມີເຄື່ອງມືທີ່ມີປະໂຫຍດໃນການຈັດການສັນຍານສະເຕີຣິໂອ, ສຳລັບການແປງການບັນທຶກສະເຕີຣິໂອແບບ M/S "
"ເປັນສັນຍານ L/R ໃນຂະນະທີ່ສາມາດຄວບຄຸມພາຣາມິເຕີ ຫຼື ການກະຈາຍພາບສະເຕີຣິໂອຂອງແທຣັກຫຼັກ. "

#: data/effects/avfilter/avfilter_stereotools.xml:8
#, kde-format
msgid "Level IN"
msgstr "ລະດັບຂາເຂົ້າ (Level IN)"

#: data/effects/avfilter/avfilter_stereotools.xml:10
#: data/effects/avfilter/avfilter_stereotools.xml:15
#, kde-format
msgid ""
"Set input level before filtering for both channels.\n"
"Allowed range is from 0.015625 to 64."
msgstr ""
"ຕັ້ງຄ່າລະດັບຂາເຂົ້າກ່ອນການກັ່ນຕອງສຳລັບທັງສອງຊ່ອງ.\n"
"ຊ່ວງທີ່ອະນຸຍາດແມ່ນຈາກ 0.015625 ຫາ 64."

#: data/effects/avfilter/avfilter_stereotools.xml:13
#, kde-format
msgid "Level OUT"
msgstr "ລະດັບຂາອອກ (Level OUT)"

#: data/effects/avfilter/avfilter_stereotools.xml:18
#: data/effects/avfilter/avfilter_stereotools.xml:79
#, kde-format
msgid "Balance IN"
msgstr "ຄວາມສົມດຸນຂາເຂົ້າ (Balance IN)"

#: data/effects/avfilter/avfilter_stereotools.xml:19
#: data/effects/avfilter/avfilter_stereotools.xml:23
#, kde-format
msgid ""
"Set input balance between both channels. Default is 0. Allowed range is from "
"-1 to 1."
msgstr ""
"ຕັ້ງຄ່າຄວາມສົມດຸນຂາເຂົ້າລະຫວ່າງທັງສອງຊ່ອງ. ຄ່າເລີ່ມຕົ້ນແມ່ນ 0. ຊ່ວງທີ່ອະນຸຍາດແມ່ນຈາກ -1 ຫາ 1."

#: data/effects/avfilter/avfilter_stereotools.xml:22
#: data/effects/avfilter/avfilter_stereotools.xml:89
#, kde-format
msgid "Balance OUT"
msgstr "ຄວາມສົມດຸນຂາອອກ (Balance OUT)"

#: data/effects/avfilter/avfilter_stereotools.xml:26
#, kde-format
msgid "Softclip"
msgstr "Softclip"

#: data/effects/avfilter/avfilter_stereotools.xml:27
#, kde-format
msgid ""
"Enable softclipping. Results in analog distortion instead of harsh digital "
"0dB clipping."
msgstr ""
"ເປີດໃຊ້ softclipping. ຈະໄດ້ຜົນເປັນການບິດເບືອນແບບອະນາລັອກ "
"ແທນທີ່ຈະເປັນການຕັດສຽງແບບດິຈິຕອລທີ່ຮຸນແຮງທີ່ 0dB."

#: data/effects/avfilter/avfilter_stereotools.xml:30
#, kde-format
msgid "Mute Left"
msgstr "ປິດສຽງຊ້າຍ"

#: data/effects/avfilter/avfilter_stereotools.xml:33
#, kde-format
msgid "Mute Right"
msgstr "ປິດສຽງຂວາ"

#: data/effects/avfilter/avfilter_stereotools.xml:36
#, kde-format
msgid "Phase Left"
msgstr "ເຟສຊ້າຍ"

#: data/effects/avfilter/avfilter_stereotools.xml:37
#, kde-format
msgid "Change the phase of the left channel."
msgstr "ປ່ຽນເຟສຂອງຊ່ອງສຽງຊ້າຍ."

#: data/effects/avfilter/avfilter_stereotools.xml:40
#, kde-format
msgid "Phase Right"
msgstr "ເຟສຂວາ"

#: data/effects/avfilter/avfilter_stereotools.xml:41
#, kde-format
msgid "Change the phase of the right channel."
msgstr "ປ່ຽນເຟສຂອງຊ່ອງສຽງຂວາ."

#: data/effects/avfilter/avfilter_stereotools.xml:44
#: data/effects/ladspa/ladspa_2153.xml:21
#, kde-format
msgid "Stereo Mode"
msgstr "ໂໝດສະເຕີຣິໂອ"

#: data/effects/avfilter/avfilter_stereotools.xml:45
#, kde-format
msgid ""
"Left/Right to Left/Right,Left/Right to Mid/Side,Mid/Side to Left/Right,Left/"
"Right to Left/Left,Left/Right to Right/Right,Left/Right to Left + Right,Left/"
"Right to Right/Left,Mid/Side to Left/Left,Mid/Side to Right/Right,Mid/Side "
"to Right/Left,Left/Right to Left - Right"
msgstr ""
"ຊ້າຍ/ຂວາ ເປັນ ຊ້າຍ/ຂວາ,ຊ້າຍ/ຂວາ ເປັນ ກາງ/ຂ້າງ,ກາງ/ຂ້າງ ເປັນ ຊ້າຍ/ຂວາ,ຊ້າຍ/ຂວາ ເປັນ ຊ້າຍ/"
"ຊ້າຍ,ຊ້າຍ/ຂວາ ເປັນ ຂວາ/ຂວາ,ຊ້າຍ/ຂວາ ເປັນ ຊ້າຍ + ຂວາ,ຊ້າຍ/ຂວາ ເປັນ ຂວາ/ຊ້າຍ,ກາງ/ຂ້າງ "
"ເປັນ ຊ້າຍ/ຊ້າຍ,ກາງ/ຂ້າງ ເປັນ ຂວາ/ຂວາ,ກາງ/ຂ້າງ ເປັນ ຂວາ/ຊ້າຍ,ຊ້າຍ/ຂວາ ເປັນ ຊ້າຍ - ຂວາ"

#: data/effects/avfilter/avfilter_stereotools.xml:48
#, kde-format
msgid "Side Level"
msgstr "ລະດັບ Side"

#: data/effects/avfilter/avfilter_stereotools.xml:49
#, kde-format
msgid ""
"Set level of side signal. Default is 1. Allowed range is from 0.015625 to 64."
msgstr "ຕັ້ງຄ່າລະດັບຂອງສັນຍານ side. ຄ່າເລີ່ມຕົ້ນແມ່ນ 1. ຊ່ວງທີ່ອະນຸຍາດແມ່ນຈາກ 0.015625 ຫາ 64."

#: data/effects/avfilter/avfilter_stereotools.xml:52
#, kde-format
msgid "Side Balance"
msgstr "ຄວາມສົມດຸນ Side"

#: data/effects/avfilter/avfilter_stereotools.xml:53
#, kde-format
msgid ""
"Set balance of side signal. Default is 0. Allowed range is from -1 to 1."
msgstr "ຕັ້ງຄ່າຄວາມສົມດຸນຂອງສັນຍານ side. ຄ່າເລີ່ມຕົ້ນແມ່ນ 0. ຊ່ວງທີ່ອະນຸຍາດແມ່ນຈາກ -1 ຫາ 1."

#: data/effects/avfilter/avfilter_stereotools.xml:56
#, kde-format
msgid "Mid Level"
msgstr "ລະດັບ Mid"

#: data/effects/avfilter/avfilter_stereotools.xml:57
#, kde-format
msgid ""
"Set level of the middle signal. Default is 1. Allowed range is from 0.015625 "
"to 64."
msgstr ""
"ຕັ້ງຄ່າລະດັບຂອງສັນຍານ middle. ຄ່າເລີ່ມຕົ້ນແມ່ນ 1. ຊ່ວງທີ່ອະນຸຍາດແມ່ນຈາກ 0.015625 ຫາ 64."

#: data/effects/avfilter/avfilter_stereotools.xml:60
#, kde-format
msgid "Mid Pan"
msgstr "Pan ກາງ"

#: data/effects/avfilter/avfilter_stereotools.xml:61
#, kde-format
msgid "Set middle signal pan. Default is 0. Allowed range is from -1 to 1."
msgstr "ຕັ້ງຄ່າ pan ຂອງສັນຍານ middle. ຄ່າເລີ່ມຕົ້ນແມ່ນ 0. ຊ່ວງທີ່ອະນຸຍາດແມ່ນຈາກ -1 ຫາ 1."

#: data/effects/avfilter/avfilter_stereotools.xml:64
#, kde-format
msgid "Stereo base"
msgstr "Stereo base"

#: data/effects/avfilter/avfilter_stereotools.xml:65
#, kde-format
msgid ""
"Set stereo base between mono and inverted channels. Default is 0. Allowed "
"range is from -1 to 1."
msgstr ""
"ຕັ້ງຄ່າ stereo base ລະຫວ່າງໂມໂນ ແລະ inverted channels. ຄ່າເລີ່ມຕົ້ນແມ່ນ 0. "
"ຊ່ວງທີ່ອະນຸຍາດແມ່ນຈາກ -1 ຫາ 1."

#: data/effects/avfilter/avfilter_stereotools.xml:69
#, kde-format
msgid ""
"Set delay in milliseconds how much to delay left from right channel and vice "
"versa. Default is 0. Allowed range is from -20 to 20."
msgstr ""
"ຕັ້ງຄ່າຄວາມໜ່ວງເປັນມິນລິວິນາທີ ວ່າຈະໜ່ວງຊ່ອງຊ້າຍຈາກຊ່ອງຂວາເທົ່າໃດ ແລະ ກົງກັນຂ້າມ. ຄ່າເລີ່ມຕົ້ນແມ່ນ 0. "
"ຊ່ວງທີ່ອະນຸຍາດແມ່ນຈາກ -20 ຫາ 20."

#: data/effects/avfilter/avfilter_stereotools.xml:72
#, kde-format
msgid "S/C level"
msgstr "ລະດັບ S/C"

#: data/effects/avfilter/avfilter_stereotools.xml:75
#, kde-format
msgid "Stereo phase"
msgstr "ເຟສສະເຕີຣິໂອ (Stereo phase)"

#: data/effects/avfilter/avfilter_stereotools.xml:76
#, kde-format
msgid "Set the stereo phase in degrees."
msgstr "ຕັ້ງຄ່າເຟສສະເຕີຣິໂອເປັນອົງສາ."

#: data/effects/avfilter/avfilter_stereotools.xml:85
#: data/effects/avfilter/avfilter_stereotools.xml:95
#, kde-format
msgid ""
"‘balance’\n"
"Classic balance mode. Attenuate one channel at a time. Gain is raised up to "
"1.\n"
"‘amplitude’\n"
"Similar to classic mode above but gain is raised up to 2.\n"
"‘power’\n"
"Equal power distribution, from -6dB to +6dB range."
msgstr ""
"'balance'\n"
"ໂໝດສົມດຸນຄລາສສິກ. ຫຼຸດຄວາມແຮງຊ່ອງໜຶ່ງໃນເວລາດຽວກັນ. ອັດຕາຂະຫຍາຍເພີ່ມຂຶ້ນສູງສຸດ 1.\n"
"'amplitude'\n"
"ຄ້າຍຄືກັບໂໝດຄລາສສິກຂ້າງເທິງ ແຕ່ອັດຕາຂະຫຍາຍເພີ່ມຂຶ້ນສູງສຸດ 2.\n"
"'power'\n"
"ການກະຈາຍພະລັງງານເທົ່າທຽມກັນ, ຈາກຊ່ວງ -6dB ຫາ +6dB."

#: data/effects/avfilter/avfilter_stereotools.xml:86
#: data/effects/avfilter/avfilter_stereotools.xml:96
#, kde-format
msgid "balance,amplitude,power"
msgstr "balance,amplitude,power"

#: data/effects/avfilter/avfilter_stereowiden.xml:4
#, kde-format
msgid "Stereo widener"
msgstr "ຕົວຂະຫຍາຍສະເຕີຣິໂອ (Stereo widener)"

#: data/effects/avfilter/avfilter_stereowiden.xml:5
#, kde-format
msgid ""
"This filter enhance the stereo effect by suppressing signal common to both "
"channels and by delaying the signal of left into right and vice versa, "
"thereby widening the stereo effect."
msgstr ""
"ຟິວເຕີນີ້ເສີມສ້າງເອັບເຟັກສະເຕີຣິໂອ ໂດຍການກົດສັນຍານທີ່ຮ່ວມກັນໃນທັງສອງຊ່ອງ ແລະ "
"ໜ່ວງສັນຍານຈາກຊ້າຍໄປຂວາ ແລະ ກົງກັນຂ້າມ, ເຮັດໃຫ້ເອັບເຟັກສະເຕີຣິໂອກວ້າງຂຶ້ນ."

#: data/effects/avfilter/avfilter_stereowiden.xml:9
#, kde-format
msgid ""
"Time in milliseconds of the delay of left signal into right and vice versa."
msgstr "ເວລາເປັນມິນລິວິນາທີຂອງການໜ່ວງສັນຍານຊ້າຍເຂົ້າໄປໃນຂວາ ແລະ ກົງກັນຂ້າມ."

#: data/effects/avfilter/avfilter_stereowiden.xml:12
#, kde-format
msgid "Feedback Gain"
msgstr "Feedback Gain"

#: data/effects/avfilter/avfilter_stereowiden.xml:14
#, kde-format
msgid ""
"Amount of gain in delayed signal into right and vice versa.\n"
"Gives a delay effect of left signal in right output and vice versa which "
"gives widening effect."
msgstr ""
"ຈຳນວນອັດຕາຂະຫຍາຍໃນສັນຍານທີ່ຖືກໜ່ວງເຂົ້າໄປໃນຂວາ ແລະ ກົງກັນຂ້າມ.\n"
"ໃຫ້ເອັບເຟັກຄວາມໜ່ວງຂອງສັນຍານຊ້າຍໃນຂາອອກຂວາ ແລະ ກົງກັນຂ້າມ ເຊິ່ງໃຫ້ເອັບເຟັກການຂະຫຍາຍກວ້າງ."

#: data/effects/avfilter/avfilter_stereowiden.xml:17
#, kde-format
msgid "Cross feed"
msgstr "Cross feed"

#: data/effects/avfilter/avfilter_stereowiden.xml:19
#, kde-format
msgid ""
"Cross feed of left into right with inverted phase. This helps in suppressing "
"the mono.\n"
"If the value is 1 it will cancel all the signal common to both channels. "
msgstr ""
"Cross feed ຂອງຊ້າຍເຂົ້າໄປໃນຂວາດ້ວຍເຟສທີ່ກັບກັນ. ອັນນີ້ຊ່ວຍໃນການກົດສັນຍານໂມໂນ.\n"
"ຖ້າຄ່າແມ່ນ 1 ມັນຈະຍົກເລີກສັນຍານທັງໝົດທີ່ຮ່ວມກັນໃນທັງສອງຊ່ອງ. "

#: data/effects/avfilter/avfilter_stereowiden.xml:22
#, kde-format
msgid "Drymix"
msgstr "Drymix"

#: data/effects/avfilter/avfilter_stereowiden.xml:23
#, kde-format
msgid "Set level of input signal of original channel."
msgstr "ຕັ້ງຄ່າລະດັບຂອງສັນຍານຂາເຂົ້າຂອງຊ່ອງຕົ້ນສະບັບ."

#: data/effects/avfilter/avfilter_swapuv.xml:4
#, kde-format
msgid "Swap UV"
msgstr ""

#: data/effects/avfilter/avfilter_swapuv.xml:5
#, kde-format
msgid "Swap U and V components"
msgstr ""

#: data/effects/avfilter/avfilter_tmix.xml:4
#, kde-format
msgid "Temporal frames Mixer"
msgstr "ຕົວປະສົມເຟຣມແບບ Temporal"

#: data/effects/avfilter/avfilter_tmix.xml:5
#, kde-format
msgid "Mix successive video frames"
msgstr "ປະສົມເຟຣມວິດີໂອທີ່ຕໍ່ເນື່ອງກັນ"

#: data/effects/avfilter/avfilter_tmix.xml:8
#, kde-format
msgid "Frames to mix"
msgstr "ເຟຣມທີ່ຈະປະສົມ"

#: data/effects/avfilter/avfilter_transpose.xml:4
#, kde-format
msgid "Transpose"
msgstr "Transpose"

#: data/effects/avfilter/avfilter_transpose.xml:5
#, kde-format
msgid "Transpose rows with columns in the input video and optionally flip it"
msgstr "Transpose ແຖວ ແລະ ຖັນ ໃນວິດີໂອຂາເຂົ້າ ແລະ ເລືອກທີ່ຈະພິກມັນໄດ້"

#: data/effects/avfilter/avfilter_transpose.xml:9
#, kde-format
msgid "Clock,Clock flip,Counter clock,Counter clock flip"
msgstr "ຕາມເຂັມໂມງ,ຕາມເຂັມໂມງພິກ,ທວນເຂັມໂມງ,ທວນເຂັມໂມງພິກ"

#: data/effects/avfilter/avfilter_transpose.xml:12
