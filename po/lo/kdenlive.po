#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:4
#, kde-format
msgid "Kaleidoscope"
msgstr "ກ້ອງສ່ອງດອກໄມ້ (Kaleidoscope)"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:5
#, kde-format
msgid "Applies a kaleidoscope effect"
msgstr "ໃຊ້ເອັບເຟັກກ້ອງສ່ອງດອກໄມ້"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:8
#, kde-format
msgid "Origin X"
msgstr "ຈຸດກຳເນີດ X"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:9
#, kde-format
msgid "Move the origin of the kaleidoscope along the X axis"
msgstr "ຍ້າຍຈຸດກຳເນີດຂອງກ້ອງສ່ອງດອກໄມ້ຕາມແກນ X"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:12
#, kde-format
msgid "Origin Y"
msgstr "ຈຸດກຳເນີດ Y"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:13
#, kde-format
msgid "Move the origin of the kaleidoscope along the Y axis"
msgstr "ຍ້າຍຈຸດກຳເນີດຂອງກ້ອງສ່ອງດອກໄມ້ຕາມແກນ Y"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:16
#, kde-format
msgid "Segmentation"
msgstr "ການແບ່ງສ່ວນ"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:18
#, kde-format
msgid ""
"Kaleidoscope segmentation / 128;<br>\n"
"        segmentations of 1, 2, or multiples of 4 work best. Default is 16"
msgstr ""
"ການແບ່ງສ່ວນກ້ອງສ່ອງດອກໄມ້ / 128;<br>\n"
"        ການແບ່ງສ່ວນ 1, 2 ຫຼື ຜົນຄູນຂອງ 4 ຈະດີທີ່ສຸດ. ຄ່າເລີ່ມຕົ້ນແມ່ນ 16"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:21
#, kde-format
msgid "Specify Source Segment"
msgstr "ລະບຸສ່ວນຕົ້ນສະບັບ"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:23
#, kde-format
msgid ""
"If checked, the source angle<br>\n"
"        is read from the <em>source segment</em>, otherwise it is auto "
"calculated"
msgstr ""
"ຖ້າເລືອກ, ມຸມຕົ້ນສະບັບ<br>\n"
"        ຈະຖືກອ່ານຈາກ <em>ສ່ວນຕົ້ນສະບັບ</em>, ຖ້າບໍ່ດັ່ງນັ້ນມັນຈະຖືກຄິດໄລ່ອັດຕະໂນມັດ"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:26
#, kde-format
msgid "Source Segment"
msgstr "ສ່ວນຕົ້ນສະບັບ"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:28
#, kde-format
msgid ""
"Center of the source segment. Only used if <em>Specify Source Segment</em> "
"is checked.<br>\n"
"        0 is in +x and rotates counter clockwise."
msgstr ""
"ຈຸດໃຈກາງຂອງສ່ວນຕົ້ນສະບັບ. ໃຊ້ສະເພາະກໍລະນີທີ່ເລືອກ <em>ລະບຸສ່ວນຕົ້ນສະບັບ</em>.<br>\n"
"        0 ຢູ່ໃນ +x ແລະ ໝຸນທວນເຂັມໂມງ."

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:31
#, kde-format
msgid "Segmentation Direction"
msgstr "ທິດທາງການແບ່ງສ່ວນ"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:32
#, kde-format
msgid "Direction of the segmentation."
msgstr "ທິດທາງຂອງການແບ່ງສ່ວນ."

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:33
#, kde-format
msgid "None,Counter Clockwise,Clockwise"
msgstr "ບໍ່ມີ,ທວນເຂັມໂມງ,ຕາມເຂັມໂມງ"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:36
#, kde-format
msgid "Reflect Edges"
msgstr "ສະທ້ອນຂອບ"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:38
#, kde-format
msgid ""
"If checked, reflections that end up outside the source reflect back into it."
"<br>\n"
"        Otherwise the specified background color is used."
msgstr ""
"ຖ້າເລືອກ, ການສະທ້ອນທີ່ອອກໄປນອກຕົ້ນສະບັບຈະສະທ້ອນກັບຄືນເຂົ້າມາ.<br>\n"
"        ຖ້າບໍ່ດັ່ງນັ້ນ ຈະໃຊ້ສີພື້ນຫຼັງທີ່ລະບຸໄວ້."

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:41
#, kde-format
msgid "Edge Threshold"
msgstr "ເກນຂອງຂອບ"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:43
#, kde-format
msgid ""
"Edge threshold / 4, reflections <br>\n"
"        outside the image but within this distance clamp to the edge."
msgstr ""
"ເກນຂອງຂອບ / 4, ການສະທ້ອນ <br>\n"
"        ທີ່ຢູ່ນອກຮູບແຕ່ຢູ່ໃນໄລຍະນີ້ຈະຖືກດຶງເຂົ້າຫາຂອບ."

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:46
#, kde-format
msgid "Preferred Corner"
msgstr "ມຸມທີ່ຕ້ອງການ"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:48
#, kde-format
msgid ""
"If <em>Reflect Edges</em> is not checked, <br>\n"
"        this parameter defines the preferred corner."
msgstr ""
"ຖ້າບໍ່ໄດ້ເລືອກ <em>ສະທ້ອນຂອບ</em>, <br>\n"
"        ພາຣາມິເຕີນີ້ຈະກຳນົດມຸມທີ່ຕ້ອງການ."

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:49
#, kde-format
msgid "Top right,Top left,Bottom left,Bottom right"
msgstr "ຂວາເທິງ,ຊ້າຍເທິງ,ຊ້າຍລຸ່ມ,ຂວາລຸ່ມ"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:52
#, kde-format
msgid "Corner Search"
msgstr "ການຄົ້ນຫາມຸມ"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:54
#, kde-format
msgid ""
"If checked, search clockwise for furthest corner.<br>\n"
"        Otherwise search counter clockwise."
msgstr ""
"ຖ້າເລືອກ, ຈະຄົ້ນຫາຕາມເຂັມໂມງສຳລັບມຸມທີ່ໄກທີ່ສຸດ.<br>\n"
"        ຖ້າບໍ່ດັ່ງນັ້ນ ຈະຄົ້ນຫາທວນເຂັມໂມງ."

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:59
#, kde-format
msgid ""
"Color to use if reflection<br>\n"
"        lies outside of the source image and not reflecting back in."
msgstr ""
"ສີທີ່ຈະໃຊ້ຖ້າການສະທ້ອນ<br>\n"
"        ຢູ່ນອກຮູບຕົ້ນສະບັບ ແລະ ບໍ່ໄດ້ສະທ້ອນກັບຄືນເຂົ້າມາ."

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:62
#, kde-format
msgid "No Alpha Background"
msgstr "ພື້ນຫຼັງບໍ່ມີອັນຟາ"

#: data/effects/frei0r/frei0r_kaleid0sc0pe.xml:64
#, kde-format
msgid ""
"If checked, the selected<br>\n"
"        color will be used, if reflection lies outside of the source image "
"and not reflecting back in."
msgstr ""
"ຖ້າເລືອກ, ສີທີ່ເລືອກໄວ້<br>\n"
"        ຈະຖືກນຳໃຊ້, ຖ້າການສະທ້ອນຢູ່ນອກຮູບຕົ້ນສະບັບ ແລະ ບໍ່ໄດ້ສະທ້ອນກັບຄືນເຂົ້າມາ."

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:4
#, kde-format
msgid "Key Spill Mop Up"
msgstr "ກຳຈັດສີສ່ວນເກີນ (Key Spill)"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:5
#, kde-format
msgid "Reduces the visibility of key color spill in chroma keying"
msgstr "ລຸດການເບິ່ງເຫັນຂອງສີສ່ວນເກີນໃນການເຈາະສີ (Chroma key)"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:8
#, kde-format
msgid "Key Color"
msgstr "ສີຫຼັກ"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:11
#, kde-format
msgid "Target Color"
msgstr "ສີເປົ້າໝາຍ"

#: data/effects/frei0r/frei0r_keyspillm0pup.xml:14
#, kde-format
msgid "Mask Type"
