#: src/dialogs/subtitleedit.cpp:285
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"Creates a new subtitle with the default length (set in <interface>Settings-"
">Configure Kdenlive…->Misc</interface>) at the current playhead position/"
"frame."
