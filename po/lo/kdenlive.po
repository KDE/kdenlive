msgstr "Grain Extract"

#: data/transitions/frei0r/frei0r_grain_extract.xml:5
#, kde-format
msgid "Perform an RGB[A] grain-extract operation between the pixel sources."
msgstr "ປະຕິບັດການ RGB[A] grain-extract ລະຫວ່າງແຫຼ່ງພິກເຊວ."

#: data/transitions/frei0r/frei0r_grain_merge.xml:4
#, kde-format
msgid "Grain Merge"
msgstr "Grain Merge"

#: data/transitions/frei0r/frei0r_grain_merge.xml:5
#, kde-format
msgid "Perform an RGB[A] grain-merge operation between the pixel sources."
msgstr "ປະຕິບັດການ RGB[A] grain-merge ລະຫວ່າງແຫຼ່ງພິກເຊວ."

#: data/transitions/frei0r/frei0r_hardlight.xml:4
