msgstr "Prilagodi ravni"

#: data/effects/frei0r/frei0r_levels.xml:13
#: data/effects/frei0r/frei0r_levels.xml:44
#: data/effects/frei0r/frei0r_levels.xml:82
#, kde-format
msgid "Input black level"
msgstr "Vhodna raven črnine"

#: data/effects/frei0r/frei0r_levels.xml:16
#: data/effects/frei0r/frei0r_levels.xml:47
#: data/effects/frei0r/frei0r_levels.xml:87
