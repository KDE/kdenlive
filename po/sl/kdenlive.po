#, kde-format
msgid "Output Volume"
msgstr "Izhodna glasnost"

#: data/effects/ladspa/ladspa_2146.xml:4
#, kde-format
msgid "TAP AutoPanner"
msgstr "TAP: samodejni zasučnik"

#: data/effects/ladspa/ladspa_2146.xml:6
#, kde-format
msgid ""
"TAP AutoPanner (LADSPA 2146)<br>\n"
"   Main use is to liven up synth tracks in the mix"
msgstr ""
"TAP: samodejni zasučnik (LADSPA 2146)<br>\n"
"   Glavna uporaba je poživitev sintetizatorskih stez v miksu"

#: data/effects/ladspa/ladspa_2146.xml:14
#, no-c-format, kde-format
msgid ""
"Sets the wideness of panning.<br>\n"
"      A setting of 100% means that mono input signal is panned between the "
"extreme left and right positions"
msgstr ""
"Določa širino sukanja.<br>\n"
"      Nastavitev 100 % pomeni, da se mono vhodni signal premika med skrajnim "
"levim in desnim položajem"

#: data/effects/ladspa/ladspa_2147.xml:4
#, kde-format
msgid "TAP DeEsser"
msgstr "TAP: odsičnik"

#: data/effects/ladspa/ladspa_2147.xml:6
#, kde-format
msgid ""
"TAP DeEsser (LADSPA 2147)<br>\n"
"   Used for attenuating higher pitched frequencies in vocals such as those "
"found in 'ess', 'shh' and 'chh' sounds."
msgstr ""
"TAP: razsičnik (LADSPA 2147)<br>\n"
"   Uporablja se za dušenje višjih frekvenc v vokalih, kot so tiste, ki jih "
"najdemo v zvokih »sss«, »ššš« in »ččč«."

#: data/effects/ladspa/ladspa_2147.xml:9
#, kde-format
msgid "Threshold Level"
msgstr "Raven praga"

#: data/effects/ladspa/ladspa_2147.xml:15
#, kde-format
msgid "Sidechain Filter"
msgstr "Filter stranskega zvoka"

#: data/effects/ladspa/ladspa_2147.xml:17
#, kde-format
msgid ""
"The chosen filter's frequency<br>\n"
"      is set by the <b>Frequency</b> parameter"
msgstr ""
"Frekvenca izbranega fiitra<br>\n"
"      je nastavljena s parametrom <b>Frekvenca</b>."

#: data/effects/ladspa/ladspa_2147.xml:18
#, kde-format
msgid "Highpass,Bandpass"
msgstr "Visokoprepustni,Pasovno-prepustni"

#: data/effects/ladspa/ladspa_2147.xml:21
#, kde-format
msgid "Monitor On"
msgstr "Ogled vključen"

#: data/effects/ladspa/ladspa_2148.xml:4
#, kde-format
msgid "TAP Vibrato"
msgstr "TAP: vibrato"

#: data/effects/ladspa/ladspa_2148.xml:6
#, kde-format
msgid ""
"TAP Vibrato (LADSPA 2148)<br>\n"
"   Modulates the pitch of its input signal with a low-frequency sinusoidal "
"signal. It is useful for guitar and synth tracks, and it can also come handy "
"if a strange effect is needed."
msgstr ""
"TAP: vibrato (LADSPA 2148)<br>\n"
"   Modulira višino vhodnega signala z nizkofrekvenčnim sinusoidnim signalom. "
"Uporaben je za kitarske in sintetizatorske steze, lahko pa pride tudi prav, "
"če je potreben čuden učinek."

#: data/effects/ladspa/ladspa_2148.xml:10
#, kde-format
msgid "Determines how fast the pitch is modulated up-down"
msgstr "Določa, kako hitro se višina tona modulira navzgor in navzdol"

#: data/effects/ladspa/ladspa_2148.xml:14
#, kde-format
msgid "Sets the amount of pitch modulation"
msgstr "Nastavi količino modulacije višine tona"

#: data/effects/ladspa/ladspa_2149.xml:4
#, kde-format
msgid "TAP Rotary Speaker"
msgstr "TAP: vrteči se zvočnik"

#: data/effects/ladspa/ladspa_2149.xml:6
#, kde-format
msgid ""
"TAP Rotary Speaker (LADSPA 2149)<br>\n"
"   Simulates the sound of rotating speakers."
msgstr ""
"TAP: vrteči se zvočnik (LADSPA 2149)<br>\n"
"   Simulira zvok vrtljivih zvočnikov."

#: data/effects/ladspa/ladspa_2149.xml:9
#, kde-format
msgid "Rotor Frequency"
msgstr "Frekvenca rotorja"

#: data/effects/ladspa/ladspa_2149.xml:12
#, kde-format
msgid "Horn Frequency"
msgstr "Frekvenca hupe"

#: data/effects/ladspa/ladspa_2149.xml:15
#, kde-format
msgid "Mic Distance"
msgstr "Oddaljenost mikrofona"

#: data/effects/ladspa/ladspa_2149.xml:18
#, kde-format
msgid "Rotor/Horn Mix"
msgstr "Mešanica rotorja in hupe"

#: data/effects/ladspa/ladspa_2150.xml:4
#, kde-format
msgid "TAP Pitch Shifter"
msgstr "TAP: zamik višine tona"

#: data/effects/ladspa/ladspa_2150.xml:6
#, kde-format
msgid ""
"TAP Pitch Shifter (LADSPA 2150)<br>\n"
"   Change the pitch in the range of plus/minus one octave."
msgstr ""
"TAP: zamik višine tona (LADSPA 2150)<br>\n"
"   Spremenite višino višine v območju plus/minus ene oktave."

#: data/effects/ladspa/ladspa_2150.xml:9
#, kde-format
msgid "Semitone Shift"
msgstr "Poltonski zamik"

#: data/effects/ladspa/ladspa_2150.xml:11
#, kde-format
msgid ""
"Does the same thing as <b>Rate Shift</b></br>\n"
"      but allows to set musically sensible pitch shift rates."
msgstr ""
"Stori enako kot <b>Zamik mere</b>,</br>\n"
"      vendar omogoča nastavitev glasbeno smiselnih hitrosti premika višine "
"tona."

#: data/effects/ladspa/ladspa_2150.xml:14
#, kde-format
msgid "Rate Shift"
msgstr "Zamik mere"

#: data/effects/ladspa/ladspa_2150.xml:16
#, kde-format
msgid ""
"Does the same thing as <b>Semitone Shift</b><br>\n"
"      but in percentage of the original pitch, so that is closer to a "
"\"physical\", non-musical approach"
msgstr ""
"Naredi enako kot <b>Poltonski zamik</b><br>,\n"
"      ampak v odstotkih prvotne višine tona, tako da je to bližje "
"»fizikalnemu«, neglasbenemu pristopu."

#: data/effects/ladspa/ladspa_2151.xml:4
#, kde-format
msgid "TAP Equalizer/BW"
msgstr "TAP: izenačevalnik/BW"

#: data/effects/ladspa/ladspa_2151.xml:6
#, kde-format
msgid ""
"TAP Equalizer (LADSPA (2151)<br>\n"
"    8-band equalizer with adjustable band center frequencies and bandwidth."
msgstr ""
"TAP: izenačevalnik (LADSPA 2151)<br>\n"
"    8-pasovni izenačevalnik z nastavljivimi frekvencami osrednjega pasu in "
"širino pasu (ŠP oz. BW)."

#: data/effects/ladspa/ladspa_2151.xml:15
#: data/effects/ladspa/ladspa_2151.xml:24
#: data/effects/ladspa/ladspa_2151.xml:33
#: data/effects/ladspa/ladspa_2151.xml:42
#: data/effects/ladspa/ladspa_2151.xml:51
#: data/effects/ladspa/ladspa_2151.xml:60
#: data/effects/ladspa/ladspa_2151.xml:69
#: data/effects/ladspa/ladspa_2151.xml:78
#, kde-format
msgid "BW"
msgstr "BW"

#: data/effects/ladspa/ladspa_2151.xml:30
#, kde-format
msgid "<Gain"
msgstr "Ojačitev"

#: data/effects/ladspa/ladspa_2152.xml:4
#, kde-format
msgid "TAP Dynamics (M)"
msgstr "TAP: dinamika (M)"

#: data/effects/ladspa/ladspa_2152.xml:6
#, kde-format
msgid ""
"TAP Dynamics Mono (LADSPA 2152)<br>\n"
"   Allows changing the dynamic content of the audio stream"
msgstr ""
"TAP: dinamika (mono) (LADSPA 2153)<br>\n"
"   Omogoča spreminjanje dinamične vsebine zvočnega toka."

#: data/effects/ladspa/ladspa_2152.xml:15
#: data/effects/ladspa/ladspa_2153.xml:15
#, kde-format
msgid "Offset Gain"
msgstr "Ojačitev zamika"

#: data/effects/ladspa/ladspa_2152.xml:18
#: data/effects/ladspa/ladspa_2153.xml:18
#, kde-format
msgid "Makeup Gain"
msgstr "Kompenzacijska ojačitev"

#: data/effects/ladspa/ladspa_2152.xml:21
#: data/effects/ladspa/ladspa_2153.xml:27
#, kde-format
msgid "Dynamics Transfer Function"
msgstr "Funkcija prenosa dinamike"

#: data/effects/ladspa/ladspa_2152.xml:22
#: data/effects/ladspa/ladspa_2153.xml:28
#, kde-format
msgid ""
"2:1 comp at -6dB,2:1 comp at -9dB,2:1 comp at -12dB,2:1 comp at -18dB,2.5 "
"comp at -18dB,3:1 comp at -12dB,3:1 comp at -15dB,Compressor/Gate,Expander,"
"Hard limiter at -6dB;Hard limiter at -12dB;Hard gate at -35dB;Soft limiter;"
"Soft knee comp/gate;Softgate below -36dB"
msgstr ""
"2:1 stisk. pri -6dB,2:1 stisk. pri -9dB,2:1 stisk. pri -12dB,2:1 stisk. pri "
"-18dB,2.5 stisk. pri -18dB,3:1 stisl. pri -12dB,3:1 stisk. pri -15dB,"
"Kompresor/vrata,Razširjevalnik,Trdi omejevalnik pri -6dB;Trdi omejevalnik "
"pri -12dB;Trda vrata pri -35dB;Mehki omejevalnik;Mehko koleno komp./vrata;"
"Mehka vrata pod -36dB"

#: data/effects/ladspa/ladspa_2153.xml:4
#, kde-format
msgid "TAP Dynamics (St)"
msgstr "TAP: dinamika (St)"

#: data/effects/ladspa/ladspa_2153.xml:6
#, kde-format
msgid ""
"TAP Dynamics Stereo (LADSPA 2153)<br>\n"
"   Allows changing the dynamic content of the audio stream"
msgstr ""
"TAP: dinamika (stereo) (LADSPA 2153)<br>\n"
"   Omogoča spreminjanje dinamične vsebine zvočnega toka."

#: data/effects/ladspa/ladspa_2153.xml:23
#, kde-format
msgid ""
"Controls how the envelope levels<br>\n"
"      are used to determine the needed gain adjustment"
msgstr ""
"Nadzira, kako se ravni ovojnice<br>\n"
"      uporabljajo za določitev potrebne prilagoditve ojačitve."

#: data/effects/ladspa/ladspa_2153.xml:24
#, kde-format
msgid "Independent,Average,Peak"
msgstr "Neodvisno,Povprečno,Vrh"

#: data/effects/ladspa/ladspa_2154.xml:4
#, kde-format
msgid "TAP Reflector"
msgstr "TAP: odbojnik"

#: data/effects/ladspa/ladspa_2154.xml:6
#, kde-format
msgid ""
"TAP Reflector (LADSPA 2154)<br>\n"
"    Creates a psychedelic reverse audio effect."
msgstr ""
"TAP: odbojnik (LADSPA 2154)<br>\n"
"    Ustvari psihedelični obratni zvočni učinek."

#: data/effects/ladspa/ladspa_2154.xml:9
#, kde-format
msgid "Fragment Length"
msgstr "Dolžina fragmenta"

#: data/effects/ladspa/ladspa_2154.xml:11
#, kde-format
msgid ""
"It is best to set it to<br>\n"
"      approximately match the tempo of the track, so the Fragment Length is "
"equal to the time of one measure."
msgstr ""
"Najbolje, da nastavite na<br>\n"
"      približno ujemanje s tempom steze, tako da je dolžina fragmenta enaka "
"času enega takta."

#: data/effects/ladspa/ladspa_2155.xml:4
#, kde-format
msgid "TAP Pink/Fractal Noise"
msgstr "TAP: roza/fraktalni šum"

#: data/effects/ladspa/ladspa_2155.xml:6
#, kde-format
msgid ""
"TAP Pink/Fractal Noise (LADSPA 2155)<br>\n"
"    Adds pink noise to the incoming signal using a one-dimensional random "
"fractal line generated by the Midpoint Displacement Method."
msgstr ""
"TAP: roza/fraktalni šum (LADSPA 2155)<br>\n"
"    Doda rožnati šum vhodnemu signalu z uporabo enodimenzionalne naključne "
"fraktalne črte, ki jo ustvari metoda premika srednje točke."

#: data/effects/ladspa/ladspa_2155.xml:9
#, kde-format
msgid "Fractal Dimension"
msgstr "Mere fraktala"

#: data/effects/ladspa/ladspa_2155.xml:12
#, kde-format
msgid "Signal Level"
msgstr "Raven signala"

#: data/effects/ladspa/ladspa_2155.xml:15
#, kde-format
msgid "Noise Level"
msgstr "Raven šuma"

#: data/effects/ladspa/ladspa_2156.xml:4
#, kde-format
msgid "TAP Fractal Doubler"
msgstr "TAP: fraktalni podvojevalnik"

#: data/effects/ladspa/ladspa_2156.xml:6
#, kde-format
msgid ""
"TAP Fractal Doubler (LADSPA 2156)<br>\n"
"    Suitable for doubling tracks with vocals, acoustic/electric guitars, "
"bass and just about any other instrument on them."
msgstr ""
"TAP: fraktalni podvojevalnik (LADSPA 2156)<br>\n"
"    Primerno za podvojitev stez z vokali, akustično / električno kitaro, "
"basom in skoraj katerim koli drugim inštrumentom na njih."

#: data/effects/ladspa/ladspa_2156.xml:9
#, kde-format
msgid "Time Tracking"
msgstr "Sledenje časa"

#: data/effects/ladspa/ladspa_2156.xml:11
#: data/effects/ladspa/ladspa_2156.xml:16
#, kde-format
msgid ""
"Determines how \"rough\" and how big<br>\n"
"      these changes are. When set to 0, changes are bigger and more chaotic "
"(\"bad backup singer\"). When set to 1, changes are smaller and smoother "
"(\"better tracking of the original\")."
msgstr ""
"Določa, kako »grobe« in kako obsežne<br>\n"
"      so te spremembe. Ko je nastavljeno na 0, so spremembe večje in bolj "
"kaotične (»slab spremljevalni vokal«). Ko je nastavljeno na 1, so spremembe "
"manjše in bolj gladke (»boljše sledenje izvirniku«)."

#: data/effects/ladspa/ladspa_2156.xml:14
#, kde-format
msgid "Pitch Tracking"
msgstr "Sledenje višine tona"

#: data/effects/ladspa/ladspa_2156.xml:23
#, kde-format
msgid "Dry Left Position"
msgstr "Levi suhi položaj"

#: data/effects/ladspa/ladspa_2156.xml:25
#: data/effects/ladspa/ladspa_2156.xml:30
#: data/effects/ladspa/ladspa_2156.xml:39
#: data/effects/ladspa/ladspa_2156.xml:44
#, kde-format
msgid ""
"These controls range between 0 and 1,<br>\n"
"      0 meaning hard left and 1 meaning hard right position."
msgstr ""
"Te vrednosti so med 0 in 1,<br>\n"
"      0 pomeni trdi levi in 1 pomeni trdi desni položaj."

#: data/effects/ladspa/ladspa_2156.xml:28
#, kde-format
msgid "Dry Right Position"
msgstr "Desni suhi položaj"

#: data/effects/ladspa/ladspa_2156.xml:37
#, kde-format
msgid "Wet Left Position"
msgstr "Levi mokri položaj"

#: data/effects/ladspa/ladspa_2156.xml:42
#, kde-format
msgid "Wet Right Position"
msgstr "Desni mokri položaj"

#: data/effects/ladspa/ladspa_2157.xml:4
#, kde-format
msgid "TAP Sigmoid Booster"
msgstr "TAP: sigmoidni okrepčevalnik"

#: data/effects/ladspa/ladspa_2157.xml:6
#, kde-format
msgid ""
"TAP Sigmoid Booster (LADSPA 2157)<br>\n"
"   Applies a time-invariant nonlinear amplitude transfer function to the "
"signal."
msgstr ""
"TAP: sigmoidni okrepčevalnik (LADSPA 2157)<br>\n"
"   Uveljavi časovno nespremenljivo funkcijo prenosa nelinearne amplitude za "
"signal."

#: data/effects/ladspa/ladspa_2157.xml:9
#, kde-format
msgid "Pre Gain"
msgstr "Predojačitev"

#: data/effects/ladspa/ladspa_2157.xml:10
#, kde-format
msgid "Scales the input signal before the transfer function is applied to it."
msgstr ""
"Spremeni mero vhodnega signala, preden se na njem uveljavi funkcija prenosa."

#: data/effects/ladspa/ladspa_2157.xml:13
#, kde-format
msgid "Post Gain"
msgstr "Poojačitev"

#: data/effects/ladspa/ladspa_2157.xml:14
#, kde-format
msgid "Can be used to adjust the output gain of the effect."
msgstr "Lahko se uporablja za prilagoditev izhodne ojačitve učinka."

#: data/effects/ladspa/ladspa_2158.xml:4
#, kde-format
msgid "TAP TubeWarmth"
msgstr "TAP: TubeWarmth"

#: data/effects/ladspa/ladspa_2158.xml:6
#, kde-format
msgid ""
"TAP TubeWarmth (LADSPA 2158)<br>\n"
"   Adds the character of vacuum tube amplification by emulating the "
"sonically desirable nonlinear characteristics of triodes. It also supports "
"emulating analog tape saturation."
msgstr ""
"TAP TubeWarmth (LADSPA 2158)<br>\n"
"   Dodaja značaj ojačitev vakuumske cevi z posnemanjem zvočno zaželenih "
"nelinearnih značilnosti triod. Podpira tudi emulacijo nasičenosti analognega "
"traku."

#: data/effects/ladspa/ladspa_2158.xml:9
#, kde-format
msgid "Drive"
msgstr "Pogon"

#: data/effects/ladspa/ladspa_2158.xml:10
#, kde-format
msgid "Adjusts the amount of the effect"
msgstr "Prilagodi količino učinka"

#: data/effects/ladspa/ladspa_2158.xml:13
#, kde-format
msgid "Tape--Tube Blend"
msgstr "Mešanica traku in cevi"

#: data/effects/ladspa/ladspa_2158.xml:14
#, kde-format
msgid "Controls the color of the TubeWarmth sound"
msgstr "Nadzoruje barvo zvoka TubeWarmth"

#: data/effects/ladspa/ladspa_2159.xml:4
#, kde-format
msgid "TAP Chorus/Flange"
msgstr "TAP: zbor/prirobnik"

#: data/effects/ladspa/ladspa_2159.xml:6
#, kde-format
msgid ""
"TAP Chorus/Flange (LADSPA 2159)<br>\n"
"    Creates traditional Chorus and Flanger effects, spiced up a bit to make "
"use of stereo processing. It sounds best on guitar and synth tracks."
msgstr ""
"TAP: zbor/prirobnik (LADSPA 2159)<br>\n"
"    Ustvarja tradicionalne učinke zbora (Chorus) in prirobnika (Flanger), ki "
"so nekoliko začinjeni za uporabo pri stereo obdelavi. Najbolje zveni s "
"kitarskimi in sintetizatorskimi stezami."

#: data/effects/ladspa/ladspa_2159.xml:11
#, kde-format
msgid ""
"Determines the LFO frequency<br>\n"
"      with which the time-varying delay is modulated. The higher the "
"frequency, the more intense the effect will be."
msgstr ""
"Določi frekvenco LFO,<br>\n"
"      s katero se modulira časovno spremenljiva zakasnitev. Višja kot je "
"frekvenca, močnejši bo učinek."

#: data/effects/ladspa/ladspa_2159.xml:14
#, kde-format
msgid "L/R Phase Shift"
msgstr "Fazni zamik L/D"

#: data/effects/ladspa/ladspa_2159.xml:16
#, kde-format
msgid ""
"Controls the phase shift between the two<br>\n"
"      LFOs. The higher this setting, the stronger the \"stereo-ness\" of the "
"effect will be. When set to 0, processing of the two channels will be in-"
"phase; when set to 180 degrees, the two LFO's are is counter-phase to create "
"the widest stereo effect."
msgstr ""
"Nadzira fazni zamik med dvema LFO-jema.<br>\n"
"      Višja kot je ta nastavitev, močnejša bo »stereo-st« učinka. Ko je "
"nastavljena na 0, bo obdelava obeh kanalov v fazi; ko sta nastavljena na 180 "
"stopinj, sta dva LFO v protifazi, da ustvarita najširši stereo učinek."

#: data/effects/ladspa/ladspa_2159.xml:21
#, kde-format
msgid ""
"Adjusts the modulation depth of the delay.<br>\n"
"      Increasing it will result in stronger modulation using the same LFO "
"frequency."
msgstr ""
"Prilagodi globino modulacije zakasnitve.<br>\n"
"      Povečanje povzroči močnejšo modulacijo z uporabo iste frekvence LFO."

#: data/effects/ladspa/ladspa_2159.xml:26
#, kde-format
msgid ""
"Determines the fixed amount of time with<br>\n"
"      which the signal is delayed after the time-varying delay has been "
"applied. The setting of this control distinguishes between the Chorus and "
"Flanger effects. Delays smaller than 10 ms can be labeled Flanger, delays "
"above 20 ms yield Chorus, and delays in the range of 10-20 ms result in a "
"blend between Chorus and Flanger."
msgstr ""
"Določa fiksno količino časa,<br>\n"
"      pri čemer je signal zakasnnjen po uporabi časovno spremenljive "
"zakasnitve. Nastavitev tega kontrolnika razlikuje med učinkoma zbora "
"(Chorus) in prirobnika (Flanger). Zakasnitve, manjše od 10 ms, se lahko "
"označijo kot prirobne, zakasnitve nad 20 ms povzročijo zbor, zakasnitve v "
"območju 10-20 ms pa povzročijo mešanico med zborom in prirobnikom."

#: data/effects/ladspa/ladspa_2159.xml:29
#, kde-format
msgid "Contour"
msgstr "Obris"

#: data/effects/ladspa/ladspa_2159.xml:31
#, kde-format
msgid ""
"The cutoff frequency of a high-pass<br>\n"
"      filter applied to the now twice-delayed signal."
msgstr ""
"Frekvenca porezave visokoprepustnega<br>\n"
"      filtra, uveljavljena na signalu s sedaj dvakratno zakasnitvijo."

#: data/effects/ladspa/ladspa_2159.xml:36
#: data/effects/ladspa/ladspa_2159.xml:41
#, kde-format
msgid ""
"Allows for a final tuning of the sound.<br>\n"
"      The strongest effect is achieved if the two settings are about the "
"same. Decreasing one of them (preferably the Wet Level, to mitigate any "
"unwanted side effects) results in a subtler effect."
msgstr ""
"Omogoča končno fino nastavitev zvoka.<br>\n"
"      Najmočnejši učinek je dosežen, če sta obe nastavitvi približno enaki. "
"Zmanjšanje ene od njih (po možnosti mokre ravni, za ublažitev neželenih "
"stranskih učinkov) ima za posledico subtilnejši učinek."

#: data/effects/ladspa/ladspa_declipper.xml:4
#, kde-format
msgid "Declipper"
msgstr "Odstranjevalnik porezav"

#: data/effects/ladspa/ladspa_declipper.xml:5
#, kde-format
msgid "LADSPA declipper audio effect"
msgstr "Zvočni učinek razprekoračnika LADSPA"

#: data/effects/ladspa/ladspa_equalizer.xml:4
#, kde-format
msgid "Equalizer"
msgstr "Izenačevalnik"

#: data/effects/ladspa/ladspa_equalizer.xml:5
#, kde-format
msgid "LADSPA equalizer audio effect"
msgstr "Zvočni učinek izravnalnika LADSPA"

#: data/effects/ladspa/ladspa_equalizer.xml:8
#, kde-format
