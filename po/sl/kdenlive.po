msgid ""
"Specify the width of the border<br>\n"
"        as % of half the vertical resolution (100% means both the top and "
"bottom half of the frame are black, i.e. there is no room for the picture)"
msgstr ""
"Določite širino obrobe<br>\n"
"        kot % polovice navpične ločljivosti (100 % pomeni, da sta zgornja in "
"spodnja polovica sličice črni, tj. ni prostora za sliko)"

#: data/effects/frei0r/frei0r_letterb0xed.xml:13
