#: data/effects/avfilter/avfilter_compensationdelay.xml:32
#, kde-format
msgid ""
"Set temperature in degrees Celsius. This is the temperature of the "
"environment."
msgstr "Nastavite temperaturo v stopinjah Celzija. To je temperatura okolja."

#: data/effects/avfilter/avfilter_crossfeed.xml:4
#, kde-format
msgid "Crossfeed"
msgstr "Navzkrižno podajanje"

#: data/effects/avfilter/avfilter_crossfeed.xml:7
#, kde-format
msgid ""
"Apply headphone crossfeed filter.\n"
"Crossfeed is the process of blending the left and right channels of stereo "
"audio recording. It is mainly used to reduce extreme stereo separation of "
"low frequencies.\n"
"The intent is to produce more speaker like sound to the listener."
msgstr ""
"Uveljavite filter navzkrižnega podajanja slušalk.\n"
"Navzkrižno podajanje je postopek mešanja levega in desnega kanala stereo "
"posnetka zvoka. Uporablja se predvsem za zmanjšanje ekstremnega stereo "
"ločevanja nizkih frekvenc.\n"
"Namen je poslušalcu ustvariti bolj zvočniškemu podobnega zvoka."

#: data/effects/avfilter/avfilter_crossfeed.xml:13
#, kde-format
msgid ""
"Set strength of crossfeed.\n"
"Default is 0.2. Allowed range is from 0 to 1. This sets gain of low shelf "
"filter for side part of stereo image.\n"
"Default is -6dB. Max allowed is -30db when strength is set to 1."
msgstr ""
"Nastavite moč navzkrižnega podajanja.\n"
"Privzeta vrednost je 0,2. Dovoljeni razpon je od 0 do 1. To nastavi ojačitev "
"nizkopoličnega filtra za stranski del stereo slike.\n"
"Privzeta vrednost je -6 dB. Največja dovoljena vrednost je -30 dB, če je moč "
"nastavljena na 1."

#: data/effects/avfilter/avfilter_crossfeed.xml:19
#, kde-format
msgid ""
"Set soundstage wideness.\n"
"Default is 0.5. Allowed range is from 0 to 1. This sets cut off frequency of "
"low shelf filter.\n"
"Default is cut off near 1550 Hz. With range set to 1 cut off frequency is "
"set to 2100 Hz. "
msgstr ""
"Nastavite širino zvočnega odra.\n"
"Privzeta vrednost je 0,5. Dovoljeni razpon je od 0 do 1. To nastavi porezavo "
"frekvence filtra z nizko polico.\n"
"Privzeto je porezano blizu 1550 Hz. Z obsegom, nastavljenim na 1, je "
"frekvenca porezave nastavljena na 2100 Hz. "

#: data/effects/avfilter/avfilter_crystalizer.xml:4
#, kde-format
msgid "Crystalizer"
msgstr "Kristalizator"

#: data/effects/avfilter/avfilter_crystalizer.xml:6
#, kde-format
msgid ""
"Simple algorithm for audio noise sharpening.\n"
"This filter linearly increases differences between each audio sample."
msgstr ""
"Preprost algoritem za ostrenje zvočnega šuma.\n"
"Ta filter linearno poveča razlike med posameznimi zvočnimi vzorci."

#: data/effects/avfilter/avfilter_crystalizer.xml:12
#, kde-format
msgid ""
"Sets the intensity of effect (default: 2.0).\n"
"Must be in range between -10.0 to 0 (unchanged sound) to 10.0 (maximum "
"effect).\n"
"To inverse filtering use negative value. "
msgstr ""
"Nastavi intenzivnost učinka (privzeto: 2,0).\n"
"Mora biti v območju od -10,0 do 0 (nespremenjen zvok) do 10,0 (največji "
"učinek).\n"
"Za inverzno filtriranje uporabite negativno vrednost. "

