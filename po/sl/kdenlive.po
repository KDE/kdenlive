#: data/effects/avfilter/avfilter_gradfun.xml:4
#, kde-format
msgid "Gradfun"
msgstr "Gradfun"

#: data/effects/avfilter/avfilter_gradfun.xml:8
#, kde-format
msgid ""
"Debands video quickly using gradients.<br>\n"
"    Fix the banding artifacts that are sometimes introduced into nearly flat "
"regions by truncation to 8-bit color depth.<br>\n"
"    Interpolate the gradients that should go where the bands are, and dither "
"them.<br><br>\n"
"    <b><i>It is designed for playback only. Do not use it prior to lossy "
"compression, because compression tends to lose the dither and bring back the "
"bands</i></b>."
msgstr ""
"Odstrani pasove videa hitro s prelivi.<br>\n"
"    Popravite artefakte pasov, ki se včasih vnesejo v skoraj ravna območja z "
"okrajšanjem na 8-bitno barvno globino.<br>\n"
"    Interpolirajte prelive, ki bi morali iti tja, kjer so pasovi, in jih "
"stresajte.<br>\n"
"    <b>Zasnovan je samo za predvajanje. Ne uporabljajte ga pred stiskanjem z "
"izgubami, ker stiskanje ponavadi izgubi stresanje in povrne trakove</b>."

#: data/effects/avfilter/avfilter_gradfun.xml:13
#, kde-format
msgid ""
"The maximum amount by which the filter will change any one pixel.<br>\n"
"       \tThis is also the threshold for detecting nearly flat regions."
msgstr ""
"Največja količina, pri kateri filter spremeni poljubno posamezno slikovno "
"točko.<br>\n"
"       \tTo je tudi prag za odkrivanje skoraj ravnih območij."

#: data/effects/avfilter/avfilter_gradfun.xml:18
#, kde-format
msgid ""
"The neighborhood to fit the gradient to.<br>\n"
"       \tA larger radius makes for smoother gradients, but also prevents the "
"filter from modifying the pixels near detailed regions."
msgstr ""
"Okolica za umestitev preliva.<br>\n"
"       \tVečji polmer omogoča bolj gladke prelive, vendar tudi preprečuje, "
"da bi filter spreminjal slikovne točke v bližini podrobnih območij."

