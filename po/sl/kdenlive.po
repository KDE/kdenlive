msgstr ""
"Osminka. Pol krajša od četrtinke (U+2669). Oglejte si <a href=\"https://sl."
"wikipedia.org/wiki/Osminka\">Wikipedia:Osminka</a>"

#: src/titler/unicodedialog.cpp:205
#, kde-format
msgid ""
"Sixteenth note (Am.) or semiquaver (Brit.). Half as long as an eighth note (U"
"+266a). See <a href=\"https://en.wikipedia.org/wiki/Sixteenth_note"
"\">Wikipedia:Sixteenth_note</a>"
msgstr ""
"Šestnajstinka. Pol krajša od osminke (U+266a). Oglejte si <a href=\"https://"
"sl.wikipedia.org/wiki/%C5%A0estnajstinka\">Wikipedia:Šestnajstinka</a>"

#: src/titler/unicodedialog.cpp:208
#, kde-format
msgid ""
"Thirty-second note (Am.) or demisemiquaver (Brit.). Half as long as a "
"sixteenth note (U+266b). See <a href=\"https://en.wikipedia.org/wiki/Thirty-"
"second_note\">Wikipedia:Thirty-second_note</a>"
