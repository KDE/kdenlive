#: src/dialogs/subtitleedit.cpp:251
#, kde-format
msgid "Edit subtitle style"
msgstr "Uredi slog podnaslovov"

#: src/dialogs/subtitleedit.cpp:252
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid "Opens a dialog to edit the current subtitle."
msgstr "Odpre pogovorno okno za urejanje trenutnega podnaslova."

#: src/dialogs/subtitleedit.cpp:279
#, kde-format
msgid "Go to next subtitle"
msgstr "Pojdi na naslednji podnaslov"

#: src/dialogs/subtitleedit.cpp:280
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"Moves the playhead in the timeline to the beginning of the subtitle to the "
"right."
msgstr "Premakne predvajalno glavo v časovnici na začetek podnaslova na desni."

#: src/dialogs/subtitleedit.cpp:281
#, kde-format
msgid "Go to previous subtitle"
msgstr "Pojdi na predhodni podnaslov"

#: src/dialogs/subtitleedit.cpp:282
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"Moves the playhead in the timeline to the beginning of the subtitle to the "
"left."
msgstr "Premakne predvajalno glavo v časovnici na začetek podnaslova na levi."

#: src/dialogs/subtitleedit.cpp:284
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"Creates a new subtitle with the default length (set in <interface>Settings-"
">Configure Kdenlive…->Misc</interface>) at the current playhead position/"
"frame."
msgstr ""
"Ustvari nov podnaslov privzete dolžine (določene pod <interface>Nastavitve→ "
"Prilagodi Kdenlive …→ Razno</interface>) na trenutne položaju/sličici "
"predvajalne glave."

#: src/dialogs/subtitleedit.cpp:286
#, kde-format
msgid "Split subtitle at cursor position"
msgstr "Razdeli podnaslov na položaju kazalca"

#: src/dialogs/subtitleedit.cpp:288
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"Cuts the subtitle text at the cursor position and creates a new subtitle to "
"the right (like cutting a clip)."
msgstr ""
"Izreže besedilo podnaslova na položaju kazalca in ustvari nov podnaslov na "
"desni (kot bi odrezali posnetek)."

#: src/dialogs/subtitleedit.cpp:289
#, kde-format
msgid "Update subtitle text"
msgstr "Posodobi besedilo podnaslova"

#: src/dialogs/subtitleedit.cpp:290
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid "Updates the subtitle display in the timeline."
msgstr "Posodobi prikaz podnaslova v časovnici."

#: src/dialogs/subtitleedit.cpp:291
#, kde-format
msgid "Show more options"
msgstr "Pokaži več možnosti"

#: src/dialogs/subtitleedit.cpp:292
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid "Toggles a list to adjust more subtitle settings."
msgstr "Preklopi seznam za prilagoditev več nastavitev podnaslovov."

#: src/dialogs/subtitleedit.cpp:294
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"Deletes the currently selected subtitle (doesn’t work on multiple subtitles)."
msgstr "Izbriše trenutno izbrani podnaslov (ne deluje na več podnaslovih)."

#: src/dialogs/subtitleedit.cpp:297
#, kde-format
msgid "Toggle bold"
msgstr "Preklopi krepko"

#: src/dialogs/subtitleedit.cpp:298
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"Toggles the bold text style for either the selected text or the text "
"following the cursor position."
msgstr ""
"Preklopi slog krepkega besedila za izbrano besedilo ali besedilo, ki sledi "
"položaju kazalke."

#: src/dialogs/subtitleedit.cpp:301
#, kde-format
msgid "Toggle italic"
msgstr "Preklopi ležeče"

#: src/dialogs/subtitleedit.cpp:303
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"Toggles the italic text style for either the selected text or the text "
"following the cursor position."
msgstr ""
"Preklopi ležeči slog besedila za izbrano besedilo ali besedilo, ki sledi "
"položaju kazalke."

#: src/dialogs/subtitleedit.cpp:306
#, kde-format
msgid "Toggle underline"
msgstr "Preklopi podčrtovanje"

#: src/dialogs/subtitleedit.cpp:308
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"Toggles the underline text style for either the selected text or the text "
"following the cursor position."
msgstr ""
"Preklopi slog podčrtanega besedila za izbrano besedilo ali besedilo, ki "
"sledi položaju kazalke."

#: src/dialogs/subtitleedit.cpp:311
#, kde-format
msgid "Toggle strikeout"
msgstr "Preklopi prečrtanje"

#: src/dialogs/subtitleedit.cpp:313
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"Toggles the strikeout text style for either the selected text or the text "
"following the cursor position."
msgstr ""
"Preklopi slog prečrtanega besedila za izbrano besedilo ali besedilo, ki "
"sledi položaju kazalke."

#: src/dialogs/subtitleedit.cpp:318
#, kde-format
msgid "Set font"
msgstr "Nastavite pisavo"

#: src/dialogs/subtitleedit.cpp:321
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"Open a font dialog to select a font and set its properties for either the "
