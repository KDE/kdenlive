msgid "Erosion"
msgstr "Erózia"

#: data/effects/avfilter/avfilter_erosion.xml:6
#, kde-format
msgid ""
"Apply erosion effect.<br>\n"
"    Simulates image erosion, an effect which will enlarge the darkest pixels "
"in the image by replacing the pixel by the local (3x3) minimum."
msgstr ""
"Použije efekt erózie.<br>\n"
"    Simuluje eróziu obrazu, efekt, ktorý zväčší najtmavšie pixely v obraze "
"nahradením pixelu lokálnym minimom (3x3)."

#: data/effects/avfilter/avfilter_exposure.xml:4
