msgctxt "Levels Effect Name"
msgid "Levels"
msgstr "Úrovne"

#: data/effects/frei0r/frei0r_levels.xml:6
#: data/effects/frei0r/frei0r_levels.xml:37
#: data/effects/frei0r/frei0r_levels.xml:68
