#: data/effects/frei0r/frei0r_bigsh0t_stabilize_360.xml:69
#, no-c-format, kde-format
msgid ""
"The amount of stabilization to apply.<br>\n"
"    \t100% means that the stabilizer will make the camera as steady as it "
"can. Smaller values reduce the amount of stabilization."
msgstr ""
"The amount of stabilization to apply.<br>\n"
"    \t100% means that the stabilizer will make the camera as steady as it "
"can. Smaller values reduce the amount of stabilization."

#: data/effects/frei0r/frei0r_bigsh0t_stabilize_360.xml:44
#, kde-format
msgid "Yaw smoothing"
msgstr "Plynulý"

#: data/effects/frei0r/frei0r_bigsh0t_stabilize_360.xml:45
#, kde-format
msgid ""
"The number of frames to use to smooth out the shakes. The higher the value, "
"the slower the camera will follow any intended motion."
msgstr ""
"The number of frames to use to smooth out the shakes. The higher the value, "
"the slower the camera will follow any intended motion."

#: data/effects/frei0r/frei0r_bigsh0t_stabilize_360.xml:48
#, kde-format
