#: data/effects/avfilter/avfilter_stereotools.xml:4
#, kde-format
msgid "Stereo tools"
msgstr "Stereo nástroje"

#: data/effects/avfilter/avfilter_stereotools.xml:5
#, kde-format
msgid ""
"This filter has some handy utilities to manage stereo signals, for "
"converting M/S stereo recordings to L/R signal while having control over the "
"parameters or spreading the stereo image of master track. "
msgstr ""
"This filter has some handy utilities to manage stereo signals, for "
"converting M/S stereo recordings to L/R signal while having control over the "
"parameters or spreading the stereo image of master track. "

#: data/effects/avfilter/avfilter_stereotools.xml:8
#, kde-format
msgid "Level IN"
msgstr "Vstupná úroveň"

#: data/effects/avfilter/avfilter_stereotools.xml:10
#: data/effects/avfilter/avfilter_stereotools.xml:15
#, kde-format
msgid ""
"Set input level before filtering for both channels.\n"
"Allowed range is from 0.015625 to 64."
msgstr ""
"Nastaviť vstupnú úroveň pred filtrovaním pre oba kanály.\n"
"Povolený rozsah je od 0,015625 do 64."

#: data/effects/avfilter/avfilter_stereotools.xml:13
#, kde-format
msgid "Level OUT"
msgstr "Výstupná úroveň"

#: data/effects/avfilter/avfilter_stereotools.xml:18
#: data/effects/avfilter/avfilter_stereotools.xml:79
#, kde-format
msgid "Balance IN"
msgstr "Vstupné vyváženie"

#: data/effects/avfilter/avfilter_stereotools.xml:19
#: data/effects/avfilter/avfilter_stereotools.xml:23
#, kde-format
msgid ""
"Set input balance between both channels. Default is 0. Allowed range is from "
"-1 to 1."
msgstr ""
"Nastaví vstupnú rovnováhu medzi oboma kanálmi. Predvolená hodnota je 0. "
"Povolený rozsah je od -1 do 1."

#: data/effects/avfilter/avfilter_stereotools.xml:22
#: data/effects/avfilter/avfilter_stereotools.xml:89
#, kde-format
msgid "Balance OUT"
msgstr "Výstupné vyváženie"

#: data/effects/avfilter/avfilter_stereotools.xml:26
#, kde-format
msgid "Softclip"
msgstr "Mäkké orezanie"

#: data/effects/avfilter/avfilter_stereotools.xml:27
#, kde-format
msgid ""
"Enable softclipping. Results in analog distortion instead of harsh digital "
"0dB clipping."
msgstr ""
"Povolí mäkké orezávanie. Výsledkom je analógové skreslenie namiesto tvrdého "
"digitálneho orezávania 0 dB."

#: data/effects/avfilter/avfilter_stereotools.xml:30
#, kde-format
msgid "Mute Left"
msgstr "Stlmiť ľavý"

#: data/effects/avfilter/avfilter_stereotools.xml:33
#, kde-format
msgid "Mute Right"
msgstr "Stlmiť pravý"

#: data/effects/avfilter/avfilter_stereotools.xml:36
#, kde-format
msgid "Phase Left"
msgstr "Ľavá fáza"

#: data/effects/avfilter/avfilter_stereotools.xml:37
#, kde-format
msgid "Change the phase of the left channel."
msgstr "Zmeniť fázu ľavého kanála."

#: data/effects/avfilter/avfilter_stereotools.xml:40
#, kde-format
msgid "Phase Right"
msgstr "Pravá fáza"

#: data/effects/avfilter/avfilter_stereotools.xml:41
#, kde-format
msgid "Change the phase of the right channel."
msgstr "Zmeniť fázu pravého kanála."

#: data/effects/avfilter/avfilter_stereotools.xml:44
#: data/effects/ladspa/ladspa_2153.xml:21
#, kde-format
msgid "Stereo Mode"
msgstr "Stereo režim"

#: data/effects/avfilter/avfilter_stereotools.xml:45
#, kde-format
msgid ""
"Left/Right to Left/Right,Left/Right to Mid/Side,Mid/Side to Left/Right,Left/"
"Right to Left/Left,Left/Right to Right/Right,Left/Right to Left + Right,Left/"
"Right to Right/Left,Mid/Side to Left/Left,Mid/Side to Right/Right,Mid/Side "
"to Right/Left,Left/Right to Left - Right"
msgstr ""
"Left/Right to Left/Right,Left/Right to Mid/Side,Mid/Side to Left/Right,Left/"
"Right to Left/Left,Left/Right to Right/Right,Left/Right to Left + Right,Left/"
"Right to Right/Left,Mid/Side to Left/Left,Mid/Side to Right/Right,Mid/Side "
"to Right/Left,Left/Right to Left - Right"

#: data/effects/avfilter/avfilter_stereotools.xml:48
#, kde-format
msgid "Side Level"
msgstr "Bočná úroveň"

#: data/effects/avfilter/avfilter_stereotools.xml:49
#, kde-format
msgid ""
"Set level of side signal. Default is 1. Allowed range is from 0.015625 to 64."
msgstr ""
"Nastaviť úroveň bočného signálu. Predvolená hodnota je 1. Povolený rozsah je "
"od 0,015625 do 64."

#: data/effects/avfilter/avfilter_stereotools.xml:52
#, kde-format
msgid "Side Balance"
msgstr "Bočné vyváženie"

#: data/effects/avfilter/avfilter_stereotools.xml:53
#, kde-format
msgid ""
"Set balance of side signal. Default is 0. Allowed range is from -1 to 1."
msgstr ""
"Nastaviť rovnováhu bočného signálu. Predvolená hodnota je 0. Povolený rozsah "
"je od -1 do 1."

#: data/effects/avfilter/avfilter_stereotools.xml:56
#, kde-format
msgid "Mid Level"
msgstr "Stredná úroveň"

#: data/effects/avfilter/avfilter_stereotools.xml:57
#, kde-format
msgid ""
"Set level of the middle signal. Default is 1. Allowed range is from 0.015625 "
"to 64."
msgstr ""
"Nastaví úroveň stredného signálu. Predvolená hodnota je 1. Povolený rozsah "
"je od 0,015625 do 64."

#: data/effects/avfilter/avfilter_stereotools.xml:60
#, kde-format
msgid "Mid Pan"
msgstr "Stredné panorámovanie"

#: data/effects/avfilter/avfilter_stereotools.xml:61
#, kde-format
msgid "Set middle signal pan. Default is 0. Allowed range is from -1 to 1."
msgstr ""
"Nastaví panoramovanie stredného signálu. Predvolená hodnota je 0. Povolený "
"rozsah je od -1 do 1."

#: data/effects/avfilter/avfilter_stereotools.xml:64
#, kde-format
msgid "Stereo base"
msgstr "Stereo základňa"

#: data/effects/avfilter/avfilter_stereotools.xml:65
#, kde-format
msgid ""
"Set stereo base between mono and inverted channels. Default is 0. Allowed "
"range is from -1 to 1."
msgstr ""
"Nastaviť stereo základňu medzi mono a invertovanými kanálmi. Predvolená "
"hodnota je 0. Povolený rozsah je od -1 do 1."

#: data/effects/avfilter/avfilter_stereotools.xml:69
#, kde-format
msgid ""
"Set delay in milliseconds how much to delay left from right channel and vice "
"versa. Default is 0. Allowed range is from -20 to 20."
msgstr ""
"Nastaviť oneskorenie v milisekundách o koľko oneskoriť ľavý kanál oproti "
"pravému a naopak. Predvolená hodnota je 0. Povolený rozsah je od -20 do 20."

#: data/effects/avfilter/avfilter_stereotools.xml:72
#, kde-format
msgid "S/C level"
msgstr "Úroveň S/C"

#: data/effects/avfilter/avfilter_stereotools.xml:75
#, kde-format
msgid "Stereo phase"
msgstr "Stereo fáza"

#: data/effects/avfilter/avfilter_stereotools.xml:76
#, kde-format
msgid "Set the stereo phase in degrees."
msgstr "Nastaví stereofónnu fázu v stupňoch."

#: data/effects/avfilter/avfilter_stereotools.xml:85
#: data/effects/avfilter/avfilter_stereotools.xml:95
#, kde-format
msgid ""
"‘balance’\n"
"Classic balance mode. Attenuate one channel at a time. Gain is raised up to "
"1.\n"
"‘amplitude’\n"
"Similar to classic mode above but gain is raised up to 2.\n"
"‘power’\n"
"Equal power distribution, from -6dB to +6dB range."
msgstr ""
"„balance“\n"
"Klasický režim vyváženia. Utlmuje jeden kanál naraz. Zosilnenie sa zvyšuje "
"až na 1.\n"
"„amplitude“\n"
"Podobné klasickému režimu vyššie, ale zosilnenie sa zvyšuje až na 2.\n"
"„power“\n"
"Rovnomerné rozloženie výkonu, rozsah od -6 dB do +6 dB."

#: data/effects/avfilter/avfilter_stereotools.xml:86
#: data/effects/avfilter/avfilter_stereotools.xml:96
#, kde-format
msgid "balance,amplitude,power"
msgstr "balance,amplitude,power"

#: data/effects/avfilter/avfilter_stereowiden.xml:4
#, kde-format
msgid "Stereo widener"
msgstr "Stereo rozširovač"

#: data/effects/avfilter/avfilter_stereowiden.xml:5
#, kde-format
msgid ""
"This filter enhance the stereo effect by suppressing signal common to both "
"channels and by delaying the signal of left into right and vice versa, "
"thereby widening the stereo effect."
msgstr ""
"Tento filter zosilňuje stereoefekt potlačením signálu spoločného pre oba "
"kanály a oneskorením signálu z ľavého do pravého kanála a naopak, čím "
"rozširuje stereoefekt."

#: data/effects/avfilter/avfilter_stereowiden.xml:9
#, kde-format
msgid ""
"Time in milliseconds of the delay of left signal into right and vice versa."
msgstr "Čas v milisekundách oneskorenia ľavého signálu do pravého a naopak."

#: data/effects/avfilter/avfilter_stereowiden.xml:12
#, kde-format
msgid "Feedback Gain"
msgstr "Nárast odozvy"

#: data/effects/avfilter/avfilter_stereowiden.xml:14
#, kde-format
msgid ""
"Amount of gain in delayed signal into right and vice versa.\n"
"Gives a delay effect of left signal in right output and vice versa which "
"gives widening effect."
msgstr ""
"Množstvo zosilnenia oneskoreného signálu do pravého kanálu a naopak.\n"
"Creuje efekt oneskorenia ľavého signálu v pravom výstupe a naopak, čo dáva "
"efekt rozšírenia."

#: data/effects/avfilter/avfilter_stereowiden.xml:17
#, kde-format
msgid "Cross feed"
msgstr "Krížové napájanie"

#: data/effects/avfilter/avfilter_stereowiden.xml:19
#, kde-format
msgid ""
"Cross feed of left into right with inverted phase. This helps in suppressing "
"the mono.\n"
"If the value is 1 it will cancel all the signal common to both channels. "
msgstr ""
"Krížové napájanie ľavého do pravého s invertovanou fázou. Pomáha pri "
"potlačení mono signálu.\n"
"Ak je hodnota 1, zruší sa všetok signál spoločný pre oba kanály. "

#: data/effects/avfilter/avfilter_stereowiden.xml:22
#, kde-format
msgid "Drymix"
msgstr "Suchý mix"

#: data/effects/avfilter/avfilter_stereowiden.xml:23
#, kde-format
msgid "Set level of input signal of original channel."
msgstr "Nastaviť úroveň vstupného signálu pôvodného kanála."

#: data/effects/avfilter/avfilter_swapuv.xml:4
#, kde-format
msgid "Swap UV"
msgstr "Prehodiť UV"

#: data/effects/avfilter/avfilter_swapuv.xml:5
#, kde-format
msgid "Swap U and V components"
msgstr "Prehodiť U a V komponenty"

#: data/effects/avfilter/avfilter_tmix.xml:4
#, kde-format
msgid "Temporal frames Mixer"
msgstr "Mixér časových snímok"

#: data/effects/avfilter/avfilter_tmix.xml:5
#, kde-format
msgid "Mix successive video frames"
msgstr "Zmiešať po sebe idúce video snímky"

#: data/effects/avfilter/avfilter_tmix.xml:8
#, kde-format
msgid "Frames to mix"
msgstr "Snímky na zmiešanie"

#: data/effects/avfilter/avfilter_transpose.xml:4
#, kde-format
msgid "Transpose"
msgstr "Transponovať"

#: data/effects/avfilter/avfilter_transpose.xml:5
#, kde-format
msgid "Transpose rows with columns in the input video and optionally flip it"
msgstr ""
"Transponovať riadky so stĺpcami vstupného videa a voliteľne ho prevrátiť"

#: data/effects/avfilter/avfilter_transpose.xml:9
#, kde-format
msgid "Clock,Clock flip,Counter clock,Counter clock flip"
msgstr "Clock,Clock flip,Counter clock,Counter clock flip"

#: data/effects/avfilter/avfilter_transpose.xml:12
#, kde-format
msgid "Override if"
msgstr "Prepísať ak"

#: data/effects/avfilter/avfilter_transpose.xml:13
#, kde-format
msgid "None,Portrait,Landscape"
msgstr "None,Portrait,Landscape"

#: data/effects/avfilter/avfilter_unsharp.xml:5
#, kde-format
msgid "Sharp/Unsharp"
msgstr "Ostrosť"

#: data/effects/avfilter/avfilter_unsharp.xml:6
#, kde-format
msgid "Sharpen or unsharpen/blur your video"
msgstr "Zostriť alebo rozostriť vaše video"

#: data/effects/avfilter/avfilter_unsharp.xml:9
#, kde-format
msgid "Luma horizontal matrix"
msgstr "Horizontálna luma matica"

#: data/effects/avfilter/avfilter_unsharp.xml:10
#, kde-format
msgid "Set the luma matrix horizontal size"
msgstr "Nastaviť horizontálnu veľkosť luma matice"

#: data/effects/avfilter/avfilter_unsharp.xml:13
#, kde-format
msgid "Luma vertical matrix"
msgstr "Vertikálna luma matica"

#: data/effects/avfilter/avfilter_unsharp.xml:14
#, kde-format
msgid "Set the luma matrix vertical size"
msgstr "Nastaviť vertikálnu veľkosť luma matice"

#: data/effects/avfilter/avfilter_unsharp.xml:19
#, kde-format
msgid ""
"Set the luma effect strength.<br>\n"
"            Reasonable values are between -1.5 and 1.5. Negative values will "
"blur the input video, while positive values will sharpen it, a value of 0 "
"will disable the effect. "
msgstr ""
"Nastaví silu efektu jasu.<br>\n"
"            Rozumné hodnoty sú medzi -1,5 a 1,5. Záporné hodnoty rozmazujú "
"vstupné video, kladné hodnoty ho ostria, hodnota 0 efekt vypne. "

#: data/effects/avfilter/avfilter_unsharp.xml:22
#, kde-format
msgid "Chroma horizontal matrix"
msgstr "Horizontálna chroma matica"

#: data/effects/avfilter/avfilter_unsharp.xml:23
#, kde-format
msgid "Set the chroma matrix horizontal size"
msgstr "Nastaviť horizontálnu veľkosť chroma matice"

#: data/effects/avfilter/avfilter_unsharp.xml:26
#, kde-format
msgid "Chroma vertical matrix"
msgstr "Vertikálna chroma matica"

#: data/effects/avfilter/avfilter_unsharp.xml:27
#, kde-format
msgid "Set the chroma matrix vertical size"
msgstr "Nastaviť vertikálnu veľkosť chroma matice"

#: data/effects/avfilter/avfilter_unsharp.xml:32
#, kde-format
msgid ""
"Set the chroma effect strength.<br>\n"
"            Reasonable values are between -1.5 and 1.5. Negative values will "
"blur the input video, while positive values will sharpen it, a value of zero "
"will disable the effect. "
msgstr ""
"Nastaví silu efektu chrominancie.<br>\n"
"            Rozumné hodnoty sú medzi -1,5 a 1,5. Záporné hodnoty rozmazujú "
"vstupné video, kladné hodnoty ho ostria, hodnota nula efekt vypne. "

#: data/effects/avfilter/avfilter_unsharp.xml:35
#, kde-format
msgid "Alpha horizontal matrix"
msgstr "Povoliť horizontálne posuny"

#: data/effects/avfilter/avfilter_unsharp.xml:36
#, kde-format
msgid "Set the alpha matrix horizontal size"
msgstr "Nastaviť horizontálnu veľkosť alfa matice"

#: data/effects/avfilter/avfilter_unsharp.xml:39
#, kde-format
msgid "Alpha vertical matrix"
msgstr "Vertikálna alfa matica"

