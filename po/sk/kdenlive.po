msgstr "Pridá čierne okraje hore a dole pre vzhľad kina"

#: data/effects/frei0r/frei0r_letterb0xed.xml:8
#, kde-format
msgid "Border Width"
msgstr "Šírka okraja"

#: data/effects/frei0r/frei0r_letterb0xed.xml:10
#, no-c-format, kde-format
msgid ""
"Specify the width of the border<br>\n"
"        as % of half the vertical resolution (100% means both the top and "
"bottom half of the frame are black, i.e. there is no room for the picture)"
msgstr ""
"Zadať šírku okraja<br>\n"
"        ako % polovice vertikálneho rozlíšenia (100 % znamená, že horná aj "
"dolná polovica snímky je čierna, t. j. pre obraz nezostáva miesto)"

#: data/effects/frei0r/frei0r_letterb0xed.xml:13
#: data/effects/frei0r/frei0r_timeout.xml:14
#: data/effects/frei0r/frei0r_transparency.xml:8 data/effects/vignette.xml:23
#, kde-format
msgid "Transparency"
msgstr "Priehľadnosť"

#: data/effects/frei0r/frei0r_levels.xml:5
