#: data/effects/frei0r/frei0r_levels.xml:121
#, kde-format
msgid "Input black level"
msgstr "Vstupná úroveň čiernej"

#: data/effects/frei0r/frei0r_levels.xml:16
#: data/effects/frei0r/frei0r_levels.xml:47
#: data/effects/frei0r/frei0r_levels.xml:87
#: data/effects/frei0r/frei0r_levels.xml:126
#, kde-format
msgid "Input white level"
msgstr "Vstupná úroveň bielej"

#: data/effects/frei0r/frei0r_levels.xml:22
#: data/effects/frei0r/frei0r_levels.xml:53
#: data/effects/frei0r/frei0r_levels.xml:97
#: data/effects/frei0r/frei0r_levels.xml:136
#, kde-format
msgid "Black output"
msgstr "Čierny výstup"

#: data/effects/frei0r/frei0r_levels.xml:25
#: data/effects/frei0r/frei0r_levels.xml:56
#: data/effects/frei0r/frei0r_levels.xml:101
#: data/effects/frei0r/frei0r_levels.xml:140
#, kde-format
msgid "White output"
msgstr "Biely výstup"

#: data/effects/frei0r/frei0r_levels.xml:28
#: data/effects/frei0r/frei0r_levels.xml:59
#: data/effects/frei0r/frei0r_levels.xml:75
#: data/effects/frei0r/frei0r_levels.xml:114
#, kde-format
msgid "Show histogram"
msgstr "Ukázať histogram"

#: data/effects/frei0r/frei0r_levels.xml:31
#: data/effects/frei0r/frei0r_levels.xml:62
#: data/effects/frei0r/frei0r_levels.xml:78
#: data/effects/frei0r/frei0r_levels.xml:117
#, kde-format
msgid "Histogram position"
msgstr "Pozícia histogramu"

#: data/effects/frei0r/frei0r_levels.xml:84
#: data/effects/frei0r/frei0r_levels.xml:123
#, kde-format
msgid ""
"Moves the black point to the right: all pixels with that value or less will "
"be black.<br>\n"
"                This makes the dark areas even darker, influences the mid-"
"tones a little and the highlights not at all. Increases contrast."
msgstr ""
"Posunie čierny bod doprava: všetky pixely s touto hodnotou alebo nižšou budú "
"čierne.<br>\n"
"                Tým sa tmavé oblasti stanú ešte tmavšími, stredné tóny "
"ovplyvní mierne a svetlé miesta vôbec nie. Zvyšuje kontrast."

#: data/effects/frei0r/frei0r_levels.xml:89
#: data/effects/frei0r/frei0r_levels.xml:128
#, kde-format
msgid ""
"Moves the white point to the left: all pixels with that value or higher will "
"be white.<br>\n"
"                This makes bright areas even brighter, influences the mid-"
"tones a little and the dark areas not at all. Increases contrast."
msgstr ""
"Posunie biely bod doľava: všetky pixely s touto hodnotou alebo vyššou budú "
"biele.<br>\n"
"                Toto spôsobí, že svetlé oblasti budú ešte svetlejšie, trochu "
"ovplyvní stredné tóny a tmavé oblasti vôbec. Zvyšuje kontrast."

#: data/effects/frei0r/frei0r_levels.xml:94
#, no-c-format, kde-format
msgid ""
"Changes the overall brightness of the image.<br>\n"
"                Affects only the mid-tones, black and white are not "
"influenced. Default is 25%, equivalent to Gamma 1.0). Lower values (moving "
"the bar to the left) make the image darker, higher values (moving the bar to "
"the right) make it brighter."
msgstr ""
"Zmení celkový jas obrazu.<br>\n"
"                Ovplyvňuje iba stredné tóny, čierna a biela nie sú "
"ovplyvnené. Predvolená hodnota je 25 %, čo zodpovedá Gama 1,0. Nižšie "
"hodnoty (posúvanie lišty doľava) urobia obraz tmavším, vyššie hodnoty "
"(posúvanie lišty doprava) ho rozjasnia."

#: data/effects/frei0r/frei0r_levels.xml:98
#: data/effects/frei0r/frei0r_levels.xml:137
#, kde-format
msgid "Opposite of Input black level"
msgstr "Opak vstupnej úrovne čiernej"

#: data/effects/frei0r/frei0r_levels.xml:102
#: data/effects/frei0r/frei0r_levels.xml:141
#, kde-format
msgid "Opposite of Input white level"
msgstr "Opak vstupnej úrovne bielej"

#: data/effects/frei0r/frei0r_levels.xml:133
#, kde-format
msgid ""
"Changes the overall brightness of the image.<br>\n"
"                Affects only the mid-tones, black and white are not "
"influenced. Default is 1. Lower values (moving the bar to the left) make the "
"image darker, higher values (moving the bar to the right) make it brighter."
msgstr ""
"Zmení celkový jas obrazu.<br>\n"
"                Ovplyvňuje iba stredné tóny, čierna a biela nie sú dotknuté. "
"Predvolená hodnota je 1. Nižšie hodnoty (posun lišty doľava) obraz stmavujú, "
"vyššie hodnoty (posun lišty doprava) ho rozjasňujú."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:5
#: data/effects/frei0r/frei0r_lightgraffiti.xml:77
#, kde-format
msgid "Light Graffiti"
msgstr "Svetelné Graffiti"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:8
#, kde-format
msgid ""
"Light Graffiti effect.\n"
"        This effect allows one to do Light Painting (i.e. painting with "
"light sources on a photo by keeping the shutter\n"
"        opened for a while), but for video."
msgstr ""
"Efekt Svetelné Graffiti.\n"
"        Tento efekt umožňuje robiť svetelné maľovanie (t.j. maľovanie so "
"svetelnými zdrojmi na fotografiu podržaním uzávierky\n"
"        otvorenej na chvíľu), ale nie pre video."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:11
#: data/effects/frei0r/frei0r_lightgraffiti.xml:83
#, kde-format
msgid "Brightness Threshold"
msgstr "Prah jasu"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:13
#: data/effects/frei0r/frei0r_lightgraffiti.xml:85
#, kde-format
msgid ""
"How bright (<code>R+G+B</code>) does a pixel need to be in order to be "
"recognized as a light source?<br/>\n"
"            Increasing this threshold requires brighter light sources (i.e. "
"more white or less color, respectively) but prevents some «false alarms» "
"where semi-bright parts, e.g. hands where colors can change quite a lot "
"compared to the background, are incorrectly recognized as light source."
msgstr ""
"How bright (<code>R+G+B</code>) does a pixel need to be in order to be "
"recognized as a light source?<br/>\n"
"            Increasing this threshold requires brighter light sources (i.e. "
"more white or less color, respectively) but prevents some «false alarms» "
"where semi-bright parts, e.g. hands where colors can change quite a lot "
"compared to the background, are incorrectly recognized as light source."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:16
#: data/effects/frei0r/frei0r_lightgraffiti.xml:88
#, kde-format
msgid "Difference Threshold"
msgstr "Rozdielový prah"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:18
#: data/effects/frei0r/frei0r_lightgraffiti.xml:90
#, kde-format
msgid ""
"How much does the strongest color channel of a pixel have to change, "
"compared to the background image (<code>max(dR, dG, dB)</code>), in order to "
"be recognized as light source? <br/>\n"
"            Increasing this threshold makes it harder for light sources to "
"be accepted on bright backgrounds, but decreases the danger of noise or "
"generally bright spots counting as light source."
msgstr ""
"How much does the strongest color channel of a pixel have to change, "
"compared to the background image (<code>max(dR, dG, dB)</code>), in order to "
"be recognized as light source? <br/>\n"
"            Increasing this threshold makes it harder for light sources to "
"be accepted on bright backgrounds, but decreases the danger of noise or "
"generally bright spots counting as light source."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:21
#: data/effects/frei0r/frei0r_lightgraffiti.xml:93
#, kde-format
msgid "Difference Sum Threshold"
msgstr "Prah rozdielového súčtu"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:23
#: data/effects/frei0r/frei0r_lightgraffiti.xml:95
#, kde-format
msgid ""
"How much does the sum of all color channels <em>relative to the background "
"image</em> (<code>dR + dG + dB</code>) have to change until a pixel is "
"recognized as a light source?<br/>\n"
"            Raising this value might, in some cases, avoid that some light "
"objects lit by the light source are added to the light mask."
msgstr ""
"How much does the sum of all color channels <em>relative to the background "
"image</em> (<code>dR + dG + dB</code>) have to change until a pixel is "
"recognized as a light source?<br/>\n"
"            Raising this value might, in some cases, avoid that some light "
"objects lit by the light source are added to the light mask."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:26
#: data/effects/frei0r/frei0r_lightgraffiti.xml:98
#, kde-format
msgid "Sensitivity"
msgstr "Citlivosť"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:28
#: data/effects/frei0r/frei0r_lightgraffiti.xml:100
#, kde-format
msgid ""
"Light sensitivity.<br/>\n"
"            For slowly moving light source try to use a lower sensitivity to "
"obtain a better exposure."
msgstr ""
"Light sensitivity.<br/>\n"
"            For slowly moving light source try to use a lower sensitivity to "
"obtain a better exposure."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:31
#: data/effects/frei0r/frei0r_lightgraffiti.xml:103
#, kde-format
msgid "Lower Overexposure"
msgstr "Nižšie preexponovanie"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:33
#: data/effects/frei0r/frei0r_lightgraffiti.xml:105
#, kde-format
msgid ""
"Lowers overexposure.<br/>\n"
"            The light mask does not get white immediately when the light "
"source is moving slowly or staying steady."
msgstr ""
"Lowers overexposure.<br/>\n"
"            The light mask does not get white immediately when the light "
"source is moving slowly or staying steady."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:36
#: data/effects/frei0r/frei0r_lightgraffiti.xml:108
#, kde-format
msgid "Dimming"
msgstr "Stmievanie"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:37
#: data/effects/frei0r/frei0r_lightgraffiti.xml:109
#, kde-format
msgid ""
"Dims the light mask. Lights will leave a fainting trail if it is set to a "
"value > 0."
msgstr ""
"Stlmí svetelnú masku. Svetlá zanechajú strácajúcu sa stopu, ak je to "
"nastavené na hodnotu > 0."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:40
#: data/effects/frei0r/frei0r_lightgraffiti.xml:112
#, kde-format
msgid "Background Weight"
msgstr "Váha pozadia"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:41
#: data/effects/frei0r/frei0r_lightgraffiti.xml:113
#, kde-format
msgid ""
"Strength of the (calculated) background image. Setting it to 100 paints the "
"light mask directly over the background, without the painting person in the "
"image if the video starts with a «clean» background image. (See the α "
"parameter.)"
msgstr ""
"Sila (vypočítaného) obrázka pozadia. Nastavenie na 100 náterov svetelnej "
"masky priamo cez pozadie bez natierajúcej osoby v obrázku, ak sa video "
"začína s «čistým» obrázkom pozadia. (Pozrieť parameter α.)"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:44
#: data/effects/frei0r/frei0r_lightgraffiti.xml:116
#, kde-format
msgid "α"
msgstr "α"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:46
#: data/effects/frei0r/frei0r_lightgraffiti.xml:118
#, kde-format
msgid ""
"Determines how the effect tries to adapt to background changes. <br/>\n"
"            The Light Graffiti effect remembers the first frame of the clip "
"it is applied to, so the clip should <em>always</em> start with the painter "
"outside of the video. If the background constantly changes, e.g. on a "
"street, try to set α > 0 to calculate an average background image."
msgstr ""
"Determines how the effect tries to adapt to background changes. <br/>\n"
"            The Light Graffiti effect remembers the first frame of the clip "
"it is applied to, so the clip should <em>always</em> start with the painter "
"outside of the video. If the background constantly changes, e.g. on a "
"street, try to set α > 0 to calculate an average background image."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:50
#: data/effects/frei0r/frei0r_lightgraffiti.xml:122
#, kde-format
msgid "Increases the saturation of lights."
msgstr "Zvyšuje sýtosť svetiel."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:53
#: data/effects/frei0r/frei0r_lightgraffiti.xml:125
#, kde-format
msgid "Show brightness statistics"
msgstr "Ukázať štatistiku jasu"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:55
#: data/effects/frei0r/frei0r_lightgraffiti.xml:127
#, kde-format
msgid ""
"The stats switches allow easy and accurate adjustment of the threshold "
"parameters.<br/>\n"
"            Example: To adjust the brightness threshold, check this box and "
"adjust the threshold until the whole light source is highlighted. Repeat the "
"same with the other parameters. Only parts that are highlighted in <em>all</"
"em> thresholds will count as light source."
msgstr ""
"The stats switches allow easy and accurate adjustment of the threshold "
"parameters.<br/>\n"
"            Example: To adjust the brightness threshold, check this box and "
"adjust the threshold until the whole light source is highlighted. Repeat the "
"same with the other parameters. Only parts that are highlighted in <em>all</"
"em> thresholds will count as light source."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:58
#: data/effects/frei0r/frei0r_lightgraffiti.xml:130
#, kde-format
msgid "Show background difference statistics"
msgstr "Ukázať štatistiku rozdielu pozadia"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:61
#: data/effects/frei0r/frei0r_lightgraffiti.xml:133
#, kde-format
msgid "Show background difference sum statistics"
msgstr "Ukázať štatistiku rozdielového súčtu pozadia"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:65
#: data/effects/frei0r/frei0r_lightgraffiti.xml:137
#, kde-format
msgid ""
"Makes the background transparent, allowing to apply a composite effect and "
"paint the light mask over a completely different video."
msgstr ""
"Robí pozadie priehľadným, čo umožňuje použiť kombinovaný efekt a namaľovať "
"svetelnú masku cez úplne odlišné video."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:68
#: data/effects/frei0r/frei0r_lightgraffiti.xml:140
#, kde-format
msgid "Nonlinear dimming"
msgstr "Nelineárne stmievanie"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:69
#: data/effects/frei0r/frei0r_lightgraffiti.xml:141
#, kde-format
msgid "If normal dimming does not look natural enough, try this one."
msgstr "Ak normálne stmievanie nevyzerá dosť prirodzene, skúsiť toto."

#. i18n: ectx: property (text), widget (QPushButton, resetProxyParams)
#. i18n: ectx: property (toolTip), widget (QToolButton, buttonReset)
#: data/effects/frei0r/frei0r_lightgraffiti.xml:72
#: data/effects/frei0r/frei0r_lightgraffiti.xml:144 src/dialogs/Splash.qml:659
#: src/dialogs/Splash.qml:1046 src/layouts/layoutmanagerdialog.cpp:99
#: src/ui/configproxy_ui.ui:205 src/ui/exportguidesdialog_ui.ui:95
#, kde-format
msgid "Reset"
msgstr "Obnoviť"

#: data/effects/frei0r/frei0r_lightgraffiti.xml:73
#: data/effects/frei0r/frei0r_lightgraffiti.xml:145
#, kde-format
msgid ""
"Resets the light mask and the background image. This is necessary e.g. if "
"you apply this effect to a clip in the timeline and then move the timeline "
"cursor from outside of the clip to the middle of it. The effect receives "
"this frame in the middle as first frame and uses it as background image. For "
"proper threshold adjusting move the timeline cursor to the beginning of the "
"clip, check the Reset box and uncheck it again."
msgstr ""
"Vynuluje svetelnú masku a obrázok pozadia. Toto je nutné napr. ak použijete "
"tento efekt na klip v časovej osi a potom presuňte kurzor časovej osi z "
"vonkajšej strany klipu do jeho stredu. Efekt dostane táto snímka v strede "
"ako prvá snímka a používa ho ako obrázok pozadia. Pre správne prispôsobenie "
"hranice presuňte kurzor časovej osi na začiatok klipu, zaškrtnite pole "
"Vynulovať a opäť zrušte zaškrtnutie poľa."

#: data/effects/frei0r/frei0r_lightgraffiti.xml:80
#, kde-format
msgid ""
"Light Graffiti effect.\n"
"        This effect allows to do Light Painting (i.e. painting with light "
"sources on a photo by keeping the shutter\n"
"        opened for a while), but for video."
msgstr ""
"Efekt Svetelné Graffiti.\n"
"        Tento efekt umožňuje robiť svetelné maľovanie (t.j. maľovanie so "
"svetelnými zdrojmi na fotografiu podržaním uzávierky\n"
"        otvorenej na chvíľu), ale nie pre video."

