#: src/titler/unicodedialog.cpp:151
#, kde-format
msgid "No-break space. &amp;nbsp; in HTML. See U+2009 and U+0020."
msgstr "Neprerušujúca medzera. &amp;nbsp; v HTML. Pozrieť U+2009 and U+0020."

#: src/titler/unicodedialog.cpp:154
#, kde-format
msgid ""
"<p><strong>&laquo;</strong> (u+00ab, <code>&amp;lfquo;</code> in HTML) and "
"<strong>&raquo;</strong> (u+00bb, <code>&amp;rfquo;</code> in HTML) are "
"called Guillemets or angle quotes. Usage in different countries: France "
"(with non-breaking Space 0x00a0), Switzerland, Germany, Finland and Sweden.</"
"p><p><strong>&lsaquo;</strong> and <strong>&rsaquo;</strong> (U+2039/203a, "
"<code>&amp;lsaquo;/&amp;rsaquo;</code>) are their single quote equivalents.</"
"p><p>See <a href=\"https://en.wikipedia.org/wiki/Guillemets\">Wikipedia:"
"Guillemets</a></p>"
msgstr ""
"<p><strong>&laquo;</strong> (u+00ab, <code>&amp;lfquo;</code> v HTML) a "
"<strong>&raquo;</strong> (u+00bb, <code>&amp;rfquo;</code> v HTML) sa "
"nazývajú Guillemets alebo šikmé úvodzovky. Použitie v rôznych krajinách: "
"Francúzsko (s neprerušujúcou medzerou 0x00a0), Švajčiarsko, Nemecko, Fínsko "
"a Švédsko.</p><p><strong>&lsaquo;</strong> a <strong>&rsaquo;</strong> (U"
"+2039/203a, <code>&amp;lsaquo;/&amp;rsaquo;</code>) sú ich ekvivalenty v "
"podobe jednoduchých úvodzoviek.</p><p>Pozrieť <a href=\"http://en.wikipedia."
"org/wiki/Guillemets\">Wikipedia: Guillemets</a></p>"

#: src/titler/unicodedialog.cpp:159
#, kde-format
msgid "En Space (width of an n)"
msgstr "En Space (medzera so šírkou n)"

#: src/titler/unicodedialog.cpp:161
#, kde-format
msgid "Em Space (width of an m)"
msgstr "Em Space (medzera so šírkou m)"

#: src/titler/unicodedialog.cpp:163
#, kde-format
msgid "Three-Per-Em Space. Width: 1/3 of one <em>em</em>"
msgstr "Three-Per-Em Space. Šírka: 1/3 medzery <em>em</em>"

#: src/titler/unicodedialog.cpp:165
#, kde-format
msgid "Four-Per-Em Space. Width: 1/4 of one <em>em</em>"
msgstr "Four-Per-Em Space. Šírka: 1/4 medzery <em>em</em>"

#: src/titler/unicodedialog.cpp:167
#, kde-format
msgid "Six-Per-Em Space. Width: 1/6 of one <em>em</em>"
msgstr "Six-Per-Em Space. Šírka: 1/6 medzery <em>em</em>"

#: src/titler/unicodedialog.cpp:169
#, kde-format
msgid ""
"Figure space (non-breaking). Width of a digit if digits have fixed width in "
"this font."
msgstr ""
"Číslová medzera (neprerušujúca). Šírka číslice, ak číslice majú pevnú šírku "
"v tomto písme."

#: src/titler/unicodedialog.cpp:171
#, kde-format
msgid ""
"Punctuation Space. Width the same as between a punctuation character and the "
"next character."
msgstr ""
"Interpunkčná medzera. Šírka je rovnaká ako medzi interpunkčným znakom a "
"nasledujúcim znakom."

#: src/titler/unicodedialog.cpp:173
#, kde-format
msgid ""
"Thin space, in HTML also &amp;thinsp;. See U+202f and <a href=\"https://en."
"wikipedia.org/wiki/Space_(punctuation)\">Wikipedia:Space_(punctuation)</a>"
msgstr ""
"Tenká medzera, v HTML tiež &amp;thinsp;. Pozrieť U+202f a <a href=\"http://"
"en.wikipedia.org/wiki/Space_(punctuation)\">Wikipedia:Space_(punctuation)</a>"

#: src/titler/unicodedialog.cpp:176
#, kde-format
msgid "Hair Space. Thinner than U+2009."
msgstr "Vlásočnicová medzera. Tenšia ako U+2009."

#: src/titler/unicodedialog.cpp:179
#, kde-format
msgid ""
"Punctuation Apostrophe. Should be used instead of U+0027. See <a href="
"\"https://en.wikipedia.org/wiki/Apostrophe\">Wikipedia:Apostrophe</a>"
msgstr ""
"Interpunkcia apostrof. Mal by byť použitý namiesto U+0027. Pozrieť <a href="
"\"http://en.wikipedia.org/wiki/Apostrophe\">Wikipedia:Apostrophe</a>"

#: src/titler/unicodedialog.cpp:181
#, kde-format
msgid ""
"<p>An en Dash (dash of the width of an n).</p><p>Usage examples: In English "
"language for value ranges (1878&#x2013;1903), for relationships/connections "
"(Zurich&#x2013;Dublin). In the German language it is also used (with "
"spaces!) for showing thoughts: &ldquo;Es war &#x2013; wie immer in den "
"Ferien &#x2013; ein regnerischer Tag.</p> <p>See <a href=\"https://en."
"wikipedia.org/wiki/Dash\">Wikipedia:Dash</a></p>"
msgstr ""
"<p>en Dash (pomlčka šírky n).</p><p> Príklady použitia: v anglickom jazyku "
"pre rozsahy hodnôt (1878&#x2013;1903), pre vzťahy/spojenia (Zurich&#x2013;"
"Dublin). V nemeckom jazyku je tiež používaná (s medzerami!) pre zobrazenie "
"myšlienok: &ldquo;Es war &#x2013; wie immer in den Ferien &#x2013; ein "
"regnerischer Tag.</p> <p>Pozrieť <a href=\"http://en.wikipedia.org/wiki/Dash"
"\">Wikipedia:Dash</a></p>"

#: src/titler/unicodedialog.cpp:186
#, kde-format
msgid ""
"<p>An em Dash (dash of the width of an m).</p><p>Usage examples: In English "
"language to mark&#x2014;like here&#x2014;thoughts. Traditionally without "
"spaces. </p><p>See <a href=\"https://en.wikipedia.org/wiki/Dash\">Wikipedia:"
"Dash</a></p>"
msgstr ""
"<p>em Dash (pomlčka šírky m).</p><p>Príklady použitia: v anglickom jazyku "
"pre označenie&#x2014;ako tu&#x2014;myšlienok. Tradične bez medzier. </"
"p><p>Pozrieť <a href=\"http://en.wikipedia.org/wiki/Dash\">Wikipedia:Dash</"
"a></p>"

#: src/titler/unicodedialog.cpp:189
#, kde-format
msgid ""
"<p>Narrow no-break space. Has the same width as U+2009.</p><p>Usage: For "
"units (spaces are marked with U+2423, &#x2423;): 230&#x2423;V, "
"&#x2212;21&#x2423;&deg;C, 50&#x2423;lb, <em>but</em> 90&deg; (no space). In "
"German for abbreviations (like: i.&#x202f;d.&#x202f;R. instead of i.&#xa0;d."
"&#xa0;R. with U+00a0).</p><p>See <a href=\"https://de.wikipedia.org/wiki/"
"Schmales_Leerzeichen\">Wikipedia:de:Schmales_Leerzeichen</a></p>"
msgstr ""
"<p>Úzka neprerušujúca medzera. Má rovnakú šírku ako U+2009.</p><p>Použitie: "
"Pre jednotky (medzery sú označené s U+2423, &#x2423;): 230&#x2423;V, "
"&#x2212;21&#x2423;&deg;C, 50&#x2423;lb, <em>ale</em> 90&deg; (žiadna "
"medzera). V nemčine pre skratky (ako: i.&#x202f;d.&#x202f;R. namiesto i."
"&#xa0;d.&#xa0;R. with U+00a0).</p><p>Pozrieť <a href=\"http://de.wikipedia."
"org/wiki/Schmales_Leerzeichen\">Wikipedia:de:Schmales_Leerzeichen</a></p>"

#: src/titler/unicodedialog.cpp:194
#, kde-format
msgid ""
"Ellipsis: If text has been left o&#x2026; See <a href=\"https://en.wikipedia."
"org/wiki/Ellipsis\">Wikipedia:Ellipsis</a>"
msgstr ""
"Tri bodky: Ak bol text ponechaný o&#x2026; Pozrieť <a href=\"http://en."
"wikipedia.org/wiki/Ellipsis\">Wikipedia:Ellipsis</a>"

#: src/titler/unicodedialog.cpp:196
