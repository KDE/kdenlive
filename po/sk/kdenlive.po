msgstr "Odšumenie snímok pomocou 3D FFT (filtrovanie vo frekvenčnej oblasti)"

#: data/effects/avfilter/avfilter_fftdnoiz.xml:10
#, kde-format
msgid ""
"Set the noise sigma constant.<br>\n"
"       \tThis sets denoising strength. Using very high sigma with low "
"overlap may give blocking artifacts."
msgstr ""
"Nastaví konštantu sigma šumu.<br>\n"
"       \tToto nastavuje silu odšumovania. Použitie veľmi vysokej hodnoty "
"sigma s malým prekrytím môže spôsobiť blokovacie artefakty."

