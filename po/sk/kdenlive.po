#, kde-format
msgid "Exposure"
msgstr "Expozícia"

#: data/effects/avfilter/avfilter_exposure.xml:5
#, kde-format
msgid "Adjust exposure of the video stream."
msgstr "Upraviť expozíciu video prúdu."

#: data/effects/avfilter/avfilter_extrastereo.xml:4
#, kde-format
msgid "Extrastereo"
msgstr "Extra stereo"

#: data/effects/avfilter/avfilter_extrastereo.xml:5
#, kde-format
msgid ""
"Linearly increases the difference between left and right channels which adds "
"some sort of \"live\" effect to playback. "
msgstr ""
"Lineárne zvyšuje rozdiel medzi ľavým a pravým kanálom, čo pridáva istý živý "
"efekt pri prehrávaní."

#: data/effects/avfilter/avfilter_extrastereo.xml:11
#, kde-format
msgid ""
"Sets the difference coefficient (default: 2.5).\n"
"0.0 means mono sound (average of both channels),\n"
"with 1.0 sound will be unchanged, with -1.0 left and right channels will be "
"swapped."
msgstr ""
"Nastaví koeficient rozdielu (predvolené: 2,5).\n"
"0,0 znamená mono zvuk (priemer oboch kanálov),\n"
"pri 1,0 zvuk zostane nezmenený, pri -1,0 sa ľavý a pravý kanál vymenia."

