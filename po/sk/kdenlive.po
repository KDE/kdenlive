#: data/effects/lumakey.xml:4
#, kde-format
msgid "Lumakey"
msgstr "Luma kľúč"

#: data/effects/lumakey.xml:6
#, kde-format
msgid ""
"This filter modifies the<br>\n"
"   alpha channel as a function of the image's luma value. This is used "
"together with a compositor to combine two images so that bright or dark "
"areas of source image are overwritten on top of the destination image."
msgstr ""
"Tento filter upravuje<br>\n"
"   alfa kanál ako funkciu hodnoty jasu obrazu. Používa sa spolu s "
"kompozitorom na kombináciu dvoch obrazov tak, aby svetlé alebo tmavé oblasti "
"zdrojového obrazu boli prepísané na vrchnú časť cieľového obrazu."

#: data/effects/lumakey.xml:11
#, kde-format
msgid ""
"Luma value that defines the<br>\n"
"      center point of transition from prelevel to postlevel opacity value."
msgstr ""
"Hodnota jasu, ktorá definuje<br>\n"
"      stredový bod prechodu z hodnoty nepriehľadnosti predúrovne na hodnotu "
"nepriehľadnosti poúrovne."

#: data/effects/lumakey.xml:16
#, kde-format
msgid ""
"This defines the width of the<br>\n"
"      transition from prelevel to postlevel luma value. Start point of "
"transition in opacity value is threshold - slope and end point is thresholt "
"+ slope, values are forced in range 0 - 255."
msgstr ""
"Definuje šírku<br>\n"
"      prechodu z hodnoty jasu predúrovne na hodnotu jasu poúrovne. "
"Počiatočný bod prechodu v hodnote nepriehľadnosti je prah - sklon a koncový "
"bod je prah + sklon, hodnoty sú vynútené v rozsahu 0 - 255."

#: data/effects/lumakey.xml:19
#, kde-format
msgid "Pre-Threshold Luma Level"
msgstr "Úroveň lumy pred prahovaním"

#: data/effects/lumakey.xml:21
#, kde-format
msgid ""
"Opacity value before the<br>\n"
"      transition in opacity value begins."
msgstr ""
"Hodnota nepriehľadnosti pred<br>\n"
"      začiatkom prechodu hodnoty nepriehľadnosti."

#: data/effects/lumakey.xml:24
#, kde-format
msgid "Post-Threshold Luma Level"
msgstr "Úroveň lumy po prahovaní"

#: data/effects/lumakey.xml:26
#, kde-format
msgid ""
"Opacity value after the<br>\n"
"      transition in opacity value ends."
msgstr ""
"Hodnota nepriehľadnosti po<br>\n"
"      skončení prechodu hodnoty nepriehľadnosti."

#: data/effects/lumaliftgaingamma.xml:4
#, kde-format
